      #{{ section_id }} .os-best-sellers__price-current {
        font-size: {{ section.settings.price_size_mobile }}px;
        line-height: 1.15;
      }
          #{{ section_id }} .os-best-sellers__swatch-link,
           #{{ section_id }} .os-best-sellers__swatch,
           #{{ section_id }} .os-best-sellers__swatch-count {
             width: 23px;
             height: 23px;
           }


    #{{ section_id }} .os-best-sellers__badge {
        top: 6px;
        left: 6px;
        z-index: 5;
        font-size: 10px;
        line-height: 1;
        font-weight: 700;
        padding: 6px 9px;
        border-radius: 3px;
        white-space: nowrap;
      }
    }
  </style>

  <script>
    (() => {
      const section = document.getElementById('{{ section_id }}');
      if (!section) return;

      const viewport = section.querySelector('[data-slider-viewport]');
      const track = section.querySelector('[data-slider-track]');
      const prevBtn = section.querySelector('[data-prev]');
      const nextBtn = section.querySelector('[data-next]');
      const currentPageEl = section.querySelector('[data-current-page]');
      const totalPagesEl = section.querySelector('[data-total-pages]');
      const slides = Array.from(section.querySelectorAll('.os-best-sellers__slide'));

      if (!viewport || !track || !slides.length) return;

      let currentPage = 0;
      let resizeTimer = null;

      function getColumns() {
        return window.innerWidth <= 989
          ? parseInt({{ section.settings.columns_mobile | json }}, 10)
          : {{ section.settings.columns_desktop | json }};
      }

      function getTotalPages() {
        const perPage = getColumns();
        return Math.max(1, Math.ceil(slides.length / perPage));
      }

      function updatePagination() {
        const totalPages = getTotalPages();
        if (currentPage >= totalPages) currentPage = totalPages - 1;

        currentPageEl.textContent = currentPage + 1;
        totalPagesEl.textContent = totalPages;
      }

     function goToPage(index) {
        if (window.innerWidth <= 749) {
            track.style.transform = 'none';
            return;
        }

        const totalPages = getTotalPages();
        currentPage = Math.max(0, Math.min(index, totalPages - 1));

        const firstSlide = slides[0];
        const slideStyles = window.getComputedStyle(track);
        const gap = parseFloat(slideStyles.columnGap || slideStyles.gap || 0);
        const slideWidth = firstSlide.getBoundingClientRect().width + gap;
        const perPage = getColumns();

        track.style.transform = `translate3d(-${currentPage * slideWidth * perPage}px, 0, 0)`;
        updatePagination();
}

      prevBtn.addEventListener('click', () => {
        goToPage(currentPage - 1);
      });

      nextBtn.addEventListener('click', () => {
        goToPage(currentPage + 1);
      });

      let isDragging = false;
      let startX = 0;
      let currentTranslate = 0;
      let prevTranslate = 0;

      function pointerDown(x) {
        isDragging = true;
        startX = x;
      }

      function pointerMove(x) {
        if (!isDragging) return;
        currentTranslate = prevTranslate + x - startX;
      }

      function pointerUp(x) {
        if (!isDragging) return;
        isDragging = false;

        const movedBy = x - startX;
        if (movedBy < -50) {
          goToPage(currentPage + 1);
        } else if (movedBy > 50) {
          goToPage(currentPage - 1);
        } else {
          goToPage(currentPage);
        }

        prevTranslate = -(
          currentPage *
          (slides[0].getBoundingClientRect().width + parseFloat(window.getComputedStyle(track).gap || 0)) *
          getColumns()
        );
      }

      viewport.addEventListener('touchstart', (e) => pointerDown(e.touches[0].clientX), { passive: true });
      viewport.addEventListener('touchmove', (e) => pointerMove(e.touches[0].clientX), { passive: true });
      viewport.addEventListener('touchend', (e) => pointerUp(e.changedTouches[0].clientX));

      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          goToPage(0);
        }, 150);
      });

      goToPage(0);
    })();
  </script>
</section>

