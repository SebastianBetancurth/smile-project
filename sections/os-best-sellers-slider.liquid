{% liquid
  assign section_id = 'os-best-sellers-' | append: section.id
  assign products_to_show = section.settings.products_to_show
  assign collection = section.settings.collection
%}

<section id="{{ section_id }}" class="os-best-sellers">
  <div class="page-width">
    <div class="os-best-sellers__header">
      {% if section.settings.heading != blank %}
        <h2 class="os-best-sellers__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="os-best-sellers__subtitle">{{ section.settings.subheading }}</div>
      {% endif %}
    </div>
  </div>

  <div class="os-best-sellers__inner{% unless section.settings.full_width %} page-width{% endunless %}{% if section.settings.full_width %} os-best-sellers__inner--full{% endif %}">
    <div class="os-best-sellers__slider-wrap">
      <div class="os-best-sellers__viewport" data-slider-viewport>
        <div class="os-best-sellers__track" data-slider-track>
          {% if collection != blank and collection.products_count > 0 %}
            {% for product in collection.products limit: products_to_show %}
              <div class="os-best-sellers__slide" {{ product.shopify_attributes }}>
                {% liquid
                  assign matched_swatch_block = blank
                  for block in section.blocks
                    if block.type == 'product_swatches'
                      if block.settings.product != blank and block.settings.product.id == product.id
                        assign matched_swatch_block = block
                        break
                      endif
                    endif
                  endfor

                  assign has_product_swatches = false
                  if matched_swatch_block != blank
                    for i in (1..12)
                      assign swatch_key = 'swatch_' | append: i
                      assign swatch_image = matched_swatch_block.settings[swatch_key]
                      if swatch_image != blank
                        assign has_product_swatches = true
                        break
                      endif
                    endfor
                  endif
                %}

                {% assign hover_image = product.images[1] %}

                <a
                  href="{{ product.url }}"
                  class="os-best-sellers__card{% if has_product_swatches %} has-swatches{% endif %}{% if hover_image != blank %} has-hover-image{% endif %}"
                >
                  <div class="os-best-sellers__media">
                    {% if section.settings.show_sold_out_badge and product.available == false %}
                      <span class="os-best-sellers__badge">{{ section.settings.sold_out_text }}</span>
                    {% endif %}

                    {% if product.featured_image != blank %}
                      <div class="os-best-sellers__image-wrap">
                        {{
                          product.featured_image
                          | image_url: width: 900
                          | image_tag:
                            class: 'os-best-sellers__image os-best-sellers__image--primary',
                            loading: 'lazy',
                            widths: '240, 360, 480, 720, 900',
                            alt: product.featured_image.alt
                          | escape
                        }}

                        {% if hover_image != blank %}
                          {{
                            hover_image
                            | image_url: width: 900
                            | image_tag:
                              class: 'os-best-sellers__image os-best-sellers__image--secondary',
                              loading: 'lazy',
                              widths: '240, 360, 480, 720, 900',
                              alt: hover_image.alt
                            | default: product.title
                            | escape
                          }}
                        {% endif %}
                      </div>
                    {% else %}
                      <div class="os-best-sellers__image-placeholder"></div>
                    {% endif %}
                  </div>
                  <div class="os-best-sellers__swatches-row">
                    {% if matched_swatch_block != blank %}
                      {% liquid
                        assign swatch_total = 0
                        for i in (1..12)
                          assign swatch_key = 'swatch_' | append: i
                          assign swatch_image = matched_swatch_block.settings[swatch_key]
                          if swatch_image != blank
                            assign swatch_total = swatch_total | plus: 1
                          endif
                        endfor
                      %}

                      {% if swatch_total > 0 %}
                        <div class="os-best-sellers__swatches" {{ matched_swatch_block.shopify_attributes }}>
                          {% for i in (1..5) %}
                            {% liquid
                              assign swatch_key = 'swatch_' | append: i
                              assign swatch_image = matched_swatch_block.settings[swatch_key]

                              assign swatch_product_key = 'swatch_product_' | append: i
                              assign swatch_product = matched_swatch_block.settings[swatch_product_key]

                              assign swatch_link_key = 'swatch_link_' | append: i
                              assign swatch_link = matched_swatch_block.settings[swatch_link_key]

                              assign final_swatch_url = blank
                              if swatch_product != blank
                                assign final_swatch_url = swatch_product.url
                              elsif swatch_link != blank
                                assign final_swatch_url = swatch_link
                              endif
                            %}
                            {% if swatch_image != blank %}
                              {% if final_swatch_url != blank %}
                                <a
                                  href="{{ final_swatch_url }}"
                                  class="os-best-sellers__swatch-link"
                                  aria-label="{{ product.title | escape }}"
                                >
                                  <span class="os-best-sellers__swatch">
                                    {{
                                      swatch_image
                                      | image_url: width: 60
                                      | image_tag:
                                        class: 'os-best-sellers__swatch-image',
                                        loading: 'lazy',
                                        widths: '30, 40, 60',
                                        alt: product.title
                                    }}
                                  </span>
                                </a>
                              {% else %}
                                <span class="os-best-sellers__swatch">
                                  {{
                                    swatch_image
                                    | image_url: width: 60
                                    | image_tag:
                                      class: 'os-best-sellers__swatch-image',
                                      loading: 'lazy',
                                      widths: '30, 40, 60',
                                      alt: product.title
                                  }}
                                </span>
                              {% endif %}
                            {% endif %}
                          {% endfor %}

                          {% if swatch_total > 5 %}
                            <span class="os-best-sellers__swatch-count">+{{ swatch_total | minus: 5 }}</span>
                          {% endif %}
                        </div>
                      {% endif %}
                    {% endif %}
                  </div>
                  <div class="os-best-sellers__content">
                    <h3 class="os-best-sellers__product-title">{{ product.title }}</h3>

                    <div class="os-best-sellers__price">
                      {% if product.compare_at_price > product.price %}
                        <span class="os-best-sellers__price-current">{{ product.price | money }}</span>
                      {% else %}
                        <span class="os-best-sellers__price-current">{{ product.price | money }}</span>
                      {% endif %}
                    </div>
                  </div>
                </a>
              </div>
            {% endfor %}
          {% else %}
            {% for i in (1..6) %}
              <div class="os-best-sellers__slide">
                <div class="os-best-sellers__card">
                  <div class="os-best-sellers__media">
                    <div class="os-best-sellers__image-placeholder"></div>
                  </div>
                  <div class="os-best-sellers__content">
                    <h3 class="os-best-sellers__product-title">Producto de ejemplo</h3>
                    <div class="os-best-sellers__price">
                      <span class="os-best-sellers__price-current">$0,00</span>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <div class="os-best-sellers__controls" data-slider-controls>
        <button
          type="button"
          class="os-best-sellers__arrow os-best-sellers__arrow--prev"
          aria-label="Anterior"
          data-prev
        >
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M12.5 4.5L7 10l5.5 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="os-best-sellers__pagination"><span data-current-page>1</span>/<span data-total-pages>1</span></div>

        <button
          type="button"
          class="os-best-sellers__arrow os-best-sellers__arrow--next"
          aria-label="Siguiente"
          data-next
        >
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7.5 4.5L13 10l-5.5 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <style>
           #{{ section_id }} {
             --bg: {{ section.settings.section_bg }};
             --card-bg: {{ section.settings.card_bg }};
             --title-color: {{ section.settings.title_color }};
             --subtitle-color: {{ section.settings.subtitle_color }};
             --product-title-color: {{ section.settings.product_title_color }};
             --price-color: {{ section.settings.price_color }};
             --badge-bg: {{ section.settings.badge_bg }};
             --badge-color: {{ section.settings.badge_color }};
             --arrow-color: {{ section.settings.arrow_color }};
             --card-radius: {{ section.settings.card_radius }}px;
             --card-gap: {{ section.settings.card_gap }}px;
             --media-height: {{ section.settings.image_height_desktop }}px;
             --media-height-mobile: {{ section.settings.image_height_mobile }}px;
             --section-padding-top: {{ section.settings.padding_top }}px;
             --section-padding-bottom: {{ section.settings.padding_bottom }}px;
             --desktop-columns: {{ section.settings.columns_desktop }};
             --mobile-columns: {{ section.settings.columns_mobile }};
             --content-height-desktop: 128px;
             --content-height-mobile: 92px;
           }
           #{{ section_id }} .os-best-sellers__badge {
              position: absolute;
              top: 8px;
              left: 8px;
              z-index: 5;
              display: inline-flex;
              align-items: center;
              justify-content: center;
              background: var(--badge-bg);
              color: var(--badge-color);
              font-size: 14.5px;
              line-height: 1;
              font-weight: 700;
              letter-spacing: 0;
              padding: 7px 10px;
              border-radius: 3px;
              text-transform: uppercase;
              white-space: nowrap;
              pointer-events: none;
            }

           #{{ section_id }}.os-best-sellers {
             background: var(--bg);
             padding-top: var(--section-padding-top);
             padding-bottom: var(--section-padding-bottom);
           }
           #{{ section_id }} .os-best-sellers__card.has-swatches .os-best-sellers__media {
             border-bottom-left-radius: 0;
             border-bottom-right-radius: 0;
           }
           #{{ section_id }} .os-best-sellers__inner--full {
             width: 100%;
             max-width: 100%;
             padding-left: 0;
             padding-right: 0;
           }

           @media screen and (min-width: 750px) {
             #{{ section_id }} .os-best-sellers__inner--full {
               padding-left: 10px;
               padding-right: 10px;
             }
           }

           @media screen and (max-width: 749px) {
             #{{ section_id }} .os-best-sellers__inner--full {
               padding-left: 12px;
               padding-right: 12px;
             }
           }

           #{{ section_id }} .os-best-sellers__header {
             max-width: 1200px;
             margin: 0 auto 28px;
           }

           @media screen and (min-width: 750px) {
             #{{ section_id }} .os-best-sellers__header {
               transform: translateX(-85px);
             }
           }

           #{{ section_id }} .os-best-sellers__title {
             margin: 0 0 0px;
             color: var(--title-color);
             font-size: {{ section.settings.heading_size }}px;
             line-height: 1.12;
             font-weight: 500;
             letter-spacing: 0;
           }

           #{{ section_id }} .os-best-sellers__subtitle {
             color: var(--subtitle-color);
             font-size: {{ section.settings.subheading_size }}px;
             line-height: 1.4;
             margin: 0;
           }

           #{{ section_id }} .os-best-sellers__slider-wrap {
             position: relative;
           }

           #{{ section_id }} .os-best-sellers__viewport {
             overflow: hidden;
             width: 100%;
           }

           #{{ section_id }} .os-best-sellers__track {
             display: flex;
             gap: var(--card-gap);
             will-change: transform;
             transition: transform 0.45s ease;
           }

           #{{ section_id }} .os-best-sellers__slide {
             min-width: calc((100% - ((var(--desktop-columns) - 1) * var(--card-gap))) / var(--desktop-columns));
             max-width: calc((100% - ((var(--desktop-columns) - 1) * var(--card-gap))) / var(--desktop-columns));
             flex: 0 0 calc((100% - ((var(--desktop-columns) - 1) * var(--card-gap))) / var(--desktop-columns));
             display: flex;
           }

             #{{ section_id }} .os-best-sellers__slide {
           height: 100%;
           display: flex;
         }

         #{{ section_id }} .os-best-sellers__card {
           position: relative;
           display: flex;
           flex-direction: column;
           text-decoration: none;
           color: inherit;
           background: transparent;
           width: 100%;
           height: 100%;
         }

        #{{ section_id }} .os-best-sellers__media {
           position: relative;
           background: var(--card-bg);
           border-radius: var(--card-radius) var(--card-radius) 0 0;
           overflow: hidden;
           line-height: 0;
           min-height: var(--media-height);
           display: flex;
           align-items: center;
           justify-content: center;
         }

        #{{ section_id }} .os-best-sellers__image {
           width: 100%;
           height: auto;
           display: block;
           object-fit: contain;
           object-position: center;
           transition: transform .35s ease;
         }
         #{{ section_id }} .os-best-sellers__image-wrap {
            position: relative;
            width: 100%;
            height: 100%;
          }

          #{{ section_id }} .os-best-sellers__image {
            display: block;
            transition: opacity .35s ease, transform .35s ease;
          }

          #{{ section_id }} .os-best-sellers__image--primary,
          #{{ section_id }} .os-best-sellers__image--secondary {
            width: 100%;
          }

          #{{ section_id }} .os-best-sellers__image--secondary {
            position: absolute;
            inset: 0;
            opacity: 0;
            pointer-events: none;
          }

          @media screen and (min-width: 750px) {
            #{{ section_id }} .os-best-sellers__card.has-hover-image:hover .os-best-sellers__image--primary {
              opacity: 0;
            }

            #{{ section_id }} .os-best-sellers__card.has-hover-image:hover .os-best-sellers__image--secondary {
              opacity: 1;
            }
            #{{ section_id }} .os-best-sellers__card:not(.has-hover-image) .os-best-sellers__image--primary {
                  opacity: 1 !important;
                }
          }

         #{{ section_id }} .os-best-sellers__card:hover .os-best-sellers__image {
           transform: scale(1.02);
         }

           #{{ section_id }} .os-best-sellers__swatches-row {
             display: none;
           }

          #{{ section_id }} .os-best-sellers__card.has-swatches .os-best-sellers__swatches-row {
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--card-bg);
            padding: 8px 10px 10px;
            min-height: 42px;
            border-top: 0;
            margin-top: -32px;
            position: relative;
            z-index: 3;
          }

           #{{ section_id }} .os-best-sellers__swatches {
             display: flex;
             align-items: center;
             justify-content: center;
             gap: 4px;
             min-height: 24px;
             padding: 0;
           }

            #{{ section_id }} .os-best-sellers__content {
              background: #ffffff;
              padding: 27px 59px 18px;
              text-align: center;
              border-bottom-left-radius: var(--card-radius);
              border-bottom-right-radius: var(--card-radius);
              min-height: var(--content-height-desktop);
              display: flex;
              flex-direction: column;
              justify-content: flex-start;
              position: relative;
              z-index: 2;
            }
            #{{ section_id }} .os-best-sellers__card.has-swatches .os-best-sellers__content {
              margin-top: -10px;
              padding-top: 33px;
            }




           #{{ section_id }} .os-best-sellers__swatch-link,
           #{{ section_id }} .os-best-sellers__swatch,
           #{{ section_id }} .os-best-sellers__swatch-count {
             width: 25px;
             height: 25px;
             border-radius: 999px;
             overflow: hidden;
             display: inline-flex;
             align-items: center;
             justify-content: center;
             background: #fff;
             box-shadow: 0 0 0 1px rgba(0,0,0,.10);
             transition: transform .22s ease, box-shadow .22s ease;
             text-decoration: none;
             flex: 0 0 auto;
           }

           #{{ section_id }} .os-best-sellers__swatch-link:hover,
           #{{ section_id }} .os-best-sellers__swatch:hover,
           #{{ section_id }} .os-best-sellers__swatch-count:hover {
             transform: translateY(-2px);
             box-shadow: 0 0 0 1px #111111, 0 4px 10px rgba(0,0,0,.12);
           }

           #{{ section_id }} .os-best-sellers__swatch-image {
             width: 100%;
             height: 100%;
             object-fit: cover;
             display: block;
           }

           #{{ section_id }} .os-best-sellers__swatch-count {
             color: #111111;
             font-size: 12px;
             font-weight: 600;
             line-height: 1;
           }

           #{{ section_id }} .os-best-sellers__content {
             background: #ffffff;
             padding: 18px 58px 18px;
             text-align: center;
             border-bottom-left-radius: var(--card-radius);
             border-bottom-right-radius: var(--card-radius);
             min-height: 128px;
             display: flex;
             flex-direction: column;
             justify-content: flex-start;
           }

           #{{ section_id }} .os-best-sellers__product-title {
             margin: 0 0 0;
             color: var(--product-title-color);
             font-size: {{ section.settings.product_title_size }}px;
            font-family: 'Pulp';
            line-height: 1.15;
            letter-spacing: normal;
            font-weight: 500;
             text-transform: none;
             min-height: 48px;
             display: flex;
             align-items: flex-start;
             justify-content: center;
             text-align: center;
           }

           #{{ section_id }} .os-best-sellers__price {
            /* margin: auto 0 0;*/
           }

           #{{ section_id }} .os-best-sellers__price-current {
             color: var(--price-color);
             font-size: {{ section.settings.price_size }}px;
             line-height: 1.2;
             font-weight: 400;
           }

           #{{ section_id }} .os-best-sellers__controls {
             display: flex;
             align-items: center;
             justify-content: center;
             gap: 20px;
             margin-top: 28px;
           }

           #{{ section_id }} .os-best-sellers__arrow {
             width: 28px;
             height: 28px;
             border: 0;
             background: transparent;
             padding: 0;
             cursor: pointer;
             color: var(--arrow-color);
             display: inline-flex;
             align-items: center;
             justify-content: center;
             opacity: .6;
             transition: opacity .2s ease, transform .2s ease;
           }

           #{{ section_id }} .os-best-sellers__arrow:hover {
             opacity: 1;
             transform: translateY(-1px);
           }

           #{{ section_id }} .os-best-sellers__arrow svg {
             width: 16px;
             height: 16px;
             display: block;
           }

           #{{ section_id }} .os-best-sellers__pagination {
             font-size: 15px;
             line-height: 1;
             color: #666;
             min-width: 42px;
             text-align: center;
           }

           @media screen and (max-width: 989px) {
             #{{ section_id }} .os-best-sellers__slide {
               min-width: calc((100% - ((var(--mobile-columns) - 1) * var(--card-gap))) / var(--mobile-columns));
               max-width: calc((100% - ((var(--mobile-columns) - 1) * var(--card-gap))) / var(--mobile-columns));
               flex: 0 0 calc((100% - ((var(--mobile-columns) - 1) * var(--card-gap))) / var(--mobile-columns));
             }

             #{{ section_id }} .os-best-sellers__card.has-swatches .os-best-sellers__media {
               height: auto;
               min-height: auto;
             }

             #{{ section_id }} .os-best-sellers__card.has-swatches .os-best-sellers__image {
               width: 100%;
               height: 100%;
               object-fit: cover;
               object-position: center;
             }

             #{{ section_id }} .os-best-sellers__image {
               width: 100%;
               height: auto;
               display: block;
             }
           }

          @media screen and (max-width: 749px) {
      #{{ section_id }} .page-width {
        padding-left: 12px;
        padding-right: 12px;
      }

