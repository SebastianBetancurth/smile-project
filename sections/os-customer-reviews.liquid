{% liquid
  assign section_id = 'os-reviews-' | append: section.id
  assign reviews_per_page = section.settings.reviews_per_page | default: 5
  assign review_star_asset = 'review_estrella.png' | asset_url
  assign verified_icon_asset = 'verified.png' | asset_url

  assign reviews_total = 0
  assign rating_5_count = 0
  assign rating_4_count = 0
  assign rating_3_count = 0
  assign rating_2_count = 0
  assign rating_1_count = 0
  assign rating_sum = 0

  for block in section.blocks
    if block.type == 'review'
      assign review_rating = block.settings.rating | plus: 0
      assign reviews_total = reviews_total | plus: 1
      assign rating_sum = rating_sum | plus: review_rating

      case review_rating
        when 5
          assign rating_5_count = rating_5_count | plus: 1
        when 4
          assign rating_4_count = rating_4_count | plus: 1
        when 3
          assign rating_3_count = rating_3_count | plus: 1
        when 2
          assign rating_2_count = rating_2_count | plus: 1
        when 1
          assign rating_1_count = rating_1_count | plus: 1
      endcase
    endif
  endfor

  assign average_rating_display = 0
  if reviews_total > 0
    assign average_rating_display = rating_sum | times: 1.0 | divided_by: reviews_total
  endif

  assign rating_5_percent = 0
  assign rating_4_percent = 0
  assign rating_3_percent = 0
  assign rating_2_percent = 0
  assign rating_1_percent = 0

  if reviews_total > 0
    assign rating_5_percent = rating_5_count | times: 100 | divided_by: reviews_total
    assign rating_4_percent = rating_4_count | times: 100 | divided_by: reviews_total
    assign rating_3_percent = rating_3_count | times: 100 | divided_by: reviews_total
    assign rating_2_percent = rating_2_count | times: 100 | divided_by: reviews_total
    assign rating_1_percent = rating_1_count | times: 100 | divided_by: reviews_total
  endif
%}

<section id="{{ section_id }}" class="os-reviews-section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="os-reviews-section__topline">
        <h2 class="os-reviews-section__heading">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="os-reviews-summary">
      <div class="os-reviews-summary__rating">
        <div class="os-reviews-summary__score-wrap">
          <span class="os-reviews-summary__score">{{ average_rating_display | round: 1 }}</span>
          <span class="os-reviews-summary__score-outof">/5</span>
        </div>

        <div class="os-reviews-stars" aria-label="Average rating {{ average_rating_display | round: 1 }} out of 5">
          {% assign rounded_rating = average_rating_display | round %}
          {% for i in (1..5) %}
            <span class="os-star-image {% if i <= rounded_rating %}is-filled{% endif %}">
              <img src="{{ review_star_asset }}" alt="" loading="lazy">
            </span>
          {% endfor %}
        </div>

        <div class="os-reviews-summary__count">De {{ reviews_total }} reseñas</div>
      </div>

      <div class="os-reviews-summary__bars">
        <div class="os-rating-bar-row">
          <span class="os-rating-bar-row__label">5</span>
          <span class="os-rating-bar-row__star-image">
            <img src="{{ review_star_asset }}" alt="" loading="lazy">
          </span>
          <div class="os-rating-bar">
            <div class="os-rating-bar__fill" style="width: {{ rating_5_percent }}%;"></div>
          </div>
          <span class="os-rating-bar-row__value">{{ rating_5_count }}</span>
        </div>

        <div class="os-rating-bar-row">
          <span class="os-rating-bar-row__label">4</span>
          <span class="os-rating-bar-row__star-image">
            <img src="{{ review_star_asset }}" alt="" loading="lazy">
          </span>
          <div class="os-rating-bar">
            <div
              class="os-rating-bar__fill"
              style="width: {% if rating_4_count > 0 and rating_4_percent < 3 %}3{% else %}{{ rating_4_percent }}{% endif %}%;"
            ></div>
          </div>
          <span class="os-rating-bar-row__value">{{ rating_4_count }}</span>
        </div>

        <div class="os-rating-bar-row">
          <span class="os-rating-bar-row__label">3</span>
          <span class="os-rating-bar-row__star-image">
            <img src="{{ review_star_asset }}" alt="" loading="lazy">
          </span>
          <div class="os-rating-bar">
            <div
              class="os-rating-bar__fill"
              style="width: {% if rating_3_count > 0 and rating_3_percent < 3 %}3{% else %}{{ rating_3_percent }}{% endif %}%;"
            ></div>
          </div>
          <span class="os-rating-bar-row__value">{{ rating_3_count }}</span>
        </div>

        <div class="os-rating-bar-row">
          <span class="os-rating-bar-row__label">2</span>
          <span class="os-rating-bar-row__star-image">
            <img src="{{ review_star_asset }}" alt="" loading="lazy">
          </span>
          <div class="os-rating-bar">
            <div
              class="os-rating-bar__fill"
              style="width: {% if rating_2_count > 0 and rating_2_percent < 3 %}3{% else %}{{ rating_2_percent }}{% endif %}%;"
            ></div>
          </div>
          <span class="os-rating-bar-row__value">{{ rating_2_count }}</span>
        </div>

        <div class="os-rating-bar-row">
          <span class="os-rating-bar-row__label">1</span>
          <span class="os-rating-bar-row__star-image">
            <img src="{{ review_star_asset }}" alt="" loading="lazy">
          </span>
          <div class="os-rating-bar">
            <div
              class="os-rating-bar__fill"
              style="width: {% if rating_1_count > 0 and rating_1_percent < 3 %}3{% else %}{{ rating_1_percent }}{% endif %}%;"
            ></div>
          </div>
          <span class="os-rating-bar-row__value">{{ rating_1_count }}</span>
        </div>
      </div>

      <div class="os-reviews-summary__cta">
        <button
          type="button"
          class="os-reviews-write-btn"
          data-review-toggle
          aria-expanded="false"
          aria-controls="ReviewForm-{{ section.id }}"
        >
          {{ section.settings.write_review_label }}
        </button>
      </div>
    </div>

    <div
      id="ReviewForm-{{ section.id }}"
      class="os-reviews-form-wrap"
      hidden
    >
      <form class="os-reviews-form" data-review-form>
        <div class="os-reviews-form__field">
          <label for="ReviewName-{{ section.id }}">{{ section.settings.name_label }}</label>
          <input
            id="ReviewName-{{ section.id }}"
            type="text"
            placeholder="{{ section.settings.name_placeholder }}"
          >
        </div>

        <div class="os-reviews-form__field">
          <label for="ReviewEmail-{{ section.id }}">{{ section.settings.email_label }}</label>
          <input
            id="ReviewEmail-{{ section.id }}"
            type="email"
            placeholder="{{ section.settings.email_placeholder }}"
          >
        </div>

        <div class="os-reviews-form__field">
          <label>{{ section.settings.rating_label }}</label>

          <div class="os-review-rating-input" data-rating-input>
            {% for i in (1..5) %}
              <button
                type="button"
                class="os-review-rating-input__star"
                data-value="{{ i }}"
                aria-label="Rate {{ i }} stars"
              >
                <img src="{{ review_star_asset }}" alt="" loading="lazy">
              </button>
            {% endfor %}
            <span class="os-review-rating-input__text" data-rating-text>0/5</span>
          </div>
        </div>

        <div class="os-reviews-form__field os-reviews-form__field--upload">
          <label for="ReviewImages-{{ section.id }}" class="os-upload-btn">
            <span class="upload-text">
              <svg
                style="vertical-align:baseline;height:17px;width:17px;fill:#ffffff;margin-right:5px"
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="17"
                viewBox="0 0 20 17"
              >
                <path d="M10 0l-5.2 4.9h3.3v5.1h3.8v-5.1h3.3l-5.2-4.9zm9.3 11.5l-3.2-2.1h-2l3.4 2.6h-3.5c-.1 0-.2.1-.2.1l-.8 2.3h-6l-.8-2.2c-.1-.1-.1-.2-.2-.2h-3.6l3.4-2.6h-2l-3.2 2.1c-.4.3-.7 1-.6 1.5l.6 3.1c.1.5.7.9 1.2.9h16.3c.6 0 1.1-.4 1.3-.9l.6-3.1c.1-.5-.2-1.2-.7-1.5z"></path>
              </svg>
              {{ section.settings.image_button_label }}
            </span>
          </label>
          <input id="ReviewImages-{{ section.id }}" type="file" multiple accept="image/*" hidden>
        </div>

        <div class="os-reviews-form__field">
          <textarea
            rows="6"
            placeholder="{{ section.settings.comment_placeholder }}"
          ></textarea>
        </div>

        <div class="os-reviews-submit-row">
          <button type="submit" class="os-reviews-submit-btn" data-submit-btn>
            {{ section.settings.submit_label }}
          </button>

          <div class="os-reviews-processing" data-review-processing hidden>
            <span class="os-reviews-processing__text">{{ section.settings.processing_text }}</span>

            <span class="os-reviews-gears" aria-hidden="true">
              <span class="os-reviews-gear os-reviews-gear--big">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M10.5 2h3l.5 2.1c.5.1 1 .3 1.5.6l1.8-1.2 2.1 2.1-1.2 1.8c.3.5.5 1 .6 1.5L22 10.5v3l-2.1.5c-.1.5-.3 1-.6 1.5l1.2 1.8-2.1 2.1-1.8-1.2c-.5.3-1 .5-1.5.6L13.5 22h-3l-.5-2.1c-.5-.1-1-.3-1.5-.6l-1.8 1.2-2.1-2.1 1.2-1.8c-.3-.5-.5-1-.6-1.5L2 13.5v-3l2.1-.5c.1-.5.3-1 .6-1.5L3.5 6.7l2.1-2.1 1.8 1.2c.5-.3 1-.5 1.5-.6L10.5 2Zm1.5 6.2A3.8 3.8 0 1 0 12 15.8a3.8 3.8 0 0 0 0-7.6Z" fill="currentColor"/>
                </svg>
              </span>

              <span class="os-reviews-gear os-reviews-gear--small">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M10.5 2h3l.5 2.1c.5.1 1 .3 1.5.6l1.8-1.2 2.1 2.1-1.2 1.8c.3.5.5 1 .6 1.5L22 10.5v3l-2.1.5c-.1.5-.3 1-.6 1.5l1.2 1.8-2.1 2.1-1.8-1.2c-.5.3-1 .5-1.5.6L13.5 22h-3l-.5-2.1c-.5-.1-1-.3-1.5-.6l-1.8 1.2-2.1-2.1 1.2-1.8c-.3-.5-.5-1-.6-1.5L2 13.5v-3l2.1-.5c.1-.5.3-1 .6-1.5L3.5 6.7l2.1-2.1 1.8 1.2c.5-.3 1-.5 1.5-.6L10.5 2Zm1.5 6.2A3.8 3.8 0 1 0 12 15.8a3.8 3.8 0 0 0 0-7.6Z" fill="currentColor"/>
                </svg>
              </span>
            </span>
          </div>
        </div>
      </form>
    </div>
    <div class="os-reviews-success" data-review-success hidden>
      {{ section.settings.success_message }}
    </div>
    <div class="os-reviews-toolbar">
      <div class="os-reviews-sort" data-sort-dropdown>
        <button
          type="button"
          class="os-reviews-sort__toggle"
          data-sort-toggle
          aria-expanded="false"
          aria-label="Open sort options"
        >
          - &nbsp
          <span class="os-reviews-sort__arrow" data-sort-arrow>
            <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
              <path d="M6 2.2v7.1M6 9.3 2.8 6.1M6 9.3l3.2-3.2" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>

        <div class="os-reviews-sort__menu" data-sort-menu hidden>
          <button type="button" class="os-reviews-sort__option is-active" data-sort="recent">
            <span>{{ section.settings.option_recent }}</span>
            <span class="os-reviews-sort__option-arrow">
              <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                <path d="M6 2.2v7.1M6 9.3 2.8 6.1M6 9.3l3.2-3.2" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>

          <button type="button" class="os-reviews-sort__option" data-sort="highest">
            <span>{{ section.settings.option_highest }}</span>
            <span class="os-reviews-sort__option-arrow">
              <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                <path d="M6 2.2v7.1M6 9.3 2.8 6.1M6 9.3l3.2-3.2" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>

          <button type="button" class="os-reviews-sort__option" data-sort="lowest">
            <span>{{ section.settings.option_lowest }}</span>
            <span class="os-reviews-sort__option-arrow">
              <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                <path d="M6 2.2v7.1M6 9.3 2.8 6.1M6 9.3l3.2-3.2" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>

          <button type="button" class="os-reviews-sort__option" data-sort="photos">
            <span>{{ section.settings.option_photos }}</span>
            <span class="os-reviews-sort__option-arrow">
              <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                <path d="M6 2.2v7.1M6 9.3 2.8 6.1M6 9.3l3.2-3.2" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
        </div>
      </div>
    </div>

    <div class="os-reviews-list" data-reviews-list>
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <article
            class="os-review-card"
            data-review-card
            data-rating="{{ block.settings.rating }}"
            data-has-photo="{% if block.settings.image != blank %}true{% else %}false{% endif %}"
            data-date="{{ block.settings.review_date | escape }}"
            data-timestamp="{{ block.settings.review_date | date: '%s' }}"
            {{ block.shopify_attributes }}
          >
            <div class="os-review-card__inner">
              <div class="os-review-card__header">
                <div class="os-review-card__name-line">
                  <span class="os-review-card__name">{{ block.settings.name }}</span>

                  {% if block.settings.verified %}
                    <span class="os-review-card__verified">
                      <span class="os-review-card__verified-text">{{ section.settings.verified_text }}</span>
                      <span class="os-review-card__verified-icon">
                        <img src="{{ verified_icon_asset }}" alt="" loading="lazy">
                      </span>
                    </span>
                  {% endif %}
                </div>

                <div class="os-review-card__stars" aria-label="{{ block.settings.rating }} out of 5">
                  {% for i in (1..5) %}
                    <span class="os-star-image {% if i <= block.settings.rating %}is-filled{% endif %}">
                      <img src="{{ review_star_asset }}" alt="" loading="lazy">
                    </span>
                  {% endfor %}
                </div>
              </div>

              {% if block.settings.text != blank %}
                <div class="os-review-card__text rte">
                  {{ block.settings.text }}
                </div>
              {% endif %}

              {% if block.settings.image != blank %}
                <div class="os-review-card__image">
                  {{
                    block.settings.image
                    | image_url: width: 700
                    | image_tag: loading: 'lazy', alt: block.settings.name
                  }}
                </div>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div class="os-reviews-pagination" data-pagination></div>
  </div>

  <style>
       @font-face {
                                 font-family: 'Pulp';
                                 src: url('{{ 'Pulp.woff2' | asset_url }}') format('woff2');
                                 font-weight:800;
                                 font-style: normal;
                                 font-display: swap;
                         }
      #{{ section_id }} {
        background: {{ section.settings.section_bg }};
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        color: {{ section.settings.text_color }};
      }

      #{{ section_id }} .page-width {
        max-width: {{ section.settings.page_width }}px;
      }

      #{{ section_id }} .os-reviews-section__topline {
        padding-bottom: 14px;
        margin-bottom: 26px;
        border-bottom: 1px solid {{ section.settings.border_color }};
      }

      #{{ section_id }} .os-reviews-section__heading {
        margin: 0;
        font-size: {{ section.settings.heading_size }}px;
        line-height: 1.2;
        letter-spacing: 0.63px;
        font-weight: 700;
        font-family: 'Circular';
        color: {{ section.settings.heading_color }};
      }

      #{{ section_id }} .os-reviews-summary {
        display: grid;
        grid-template-columns: 1.1fr 1.7fr .95fr;
        gap: 52px;
        align-items: center;
        padding-bottom: 26px;
        border-bottom: 1px solid {{ section.settings.border_color }};
          }
          #{{ section_id }} .os-reviews-success {
          margin-top: 18px;
          margin-bottom: 22px;
          padding: 20px 22px;
          background: #f3f3f3;
          color: #111111;
          border-radius: 18px;
          font-size: 15px;
          line-height: 1.4;
          font-weight: 600;
          }

      #{{ section_id }} .os-reviews-summary__rating,
      #{{ section_id }} .os-reviews-summary__bars,
      #{{ section_id }} .os-reviews-summary__cta {
        position: relative;
      }
      #{{ section_id }} .os-reviews-summary__rating {
         padding-left: 28px;
         padding-bottom: 38px;
       }
      #{{ section_id }} .os-reviews-sort__option-arrow {
         display: inline-flex;
         align-items: center;
         justify-content: center;
         width: 14px;
         height: 14px;
         transform: rotate(-90deg);
         flex-shrink: 0;
         }

         #{{ section_id }} .os-reviews-sort__option-arrow svg {
         width: 14px;
         height: 14px;
         display: block;
         }

      #{{ section_id }} .os-reviews-summary__rating::after,
      #{{ section_id }} .os-reviews-summary__bars::after {
        content: "";
        position: absolute;
        top: 8px;
        right: -17px;
        width: 1px;
        height: calc(100% - 16px);
        background: {{ section.settings.border_color }};
      }

      #{{ section_id }} .os-reviews-summary__score-wrap {
        display: flex;
        align-items: flex-start;
        gap: 2px;
        margin-bottom: 8px;
      }

      #{{ section_id }} .os-reviews-summary__score {
        font-size: 68px;
        font-family: 'Circular';
        line-height: .9;
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      #{{ section_id }} .os-reviews-summary__score-outof {
        font-size: 18px;
        line-height: 1;
        font-weight: 700;
        margin-top: 9px;
        font-family: 'Circular';
      }

     #{{ section_id }} .os-reviews-stars {
         display: flex;
         align-items: center;
         gap: 0;
         margin-bottom: 2px;
         }

     #{{ section_id }} .os-star,
      #{{ section_id }} .os-star-image {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      }

      #{{ section_id }} .os-star-image img {
         display: block;
         width: 24px;
         height: 24px;
         object-fit: contain;
         }
         #{{ section_id }} .os-reviews-stars .os-star-image {
         margin-right: -2px;
         }

      #{{ section_id }} .os-star-image:not(.is-filled) img {
      opacity: 0.28;
      }

      #{{ section_id }} .os-star.is-filled {
        color: {{ section.settings.star_color }};
      }

      #{{ section_id }} .os-reviews-summary__count {
        font-size: 11px;
        font-family: 'Pulp';
        margin-left: 6px;
        color: {{ section.settings.muted_text_color }};
        font-weight: 600;
      }

      #{{ section_id }} .os-reviews-summary__bars {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      #{{ section_id }} .os-rating-bar-row {
        display: grid;
        grid-template-columns: 8px 16px minmax(0, 1fr) auto;
        align-items: center;
        gap: 12px;
      }

     #{{ section_id }} .os-rating-bar-row__label {
         font-size: 14px;
         font-weight: 700;
         line-height: 1;
         font-family: 'Circular';
         }

         #{{ section_id }} .os-rating-bar-row__star-image {
         display: inline-flex;
         align-items: center;
         justify-content: center;
         line-height: 1;
         }

         #{{ section_id }} .os-rating-bar-row__star-image img {
         display: block;
         width: 30px;
         height: 26px;
         object-fit: contain;
         }

      #{{ section_id }} .os-rating-bar {
          position: relative;
          height: 10px;
          border-radius: 999px;
          background: {{ section.settings.bar_bg }};
          overflow: hidden;
          }

      #{{ section_id }} .os-rating-bar__fill {
          position: absolute;
          top: 0;
          left: 0;
          bottom: 0;
          width: 0;
          background: {{ section.settings.bar_fill }};
          border-radius: 999px;
          display: block;
          }

      #{{ section_id }} .os-rating-bar-row__value {
        min-width: 48px;
        padding: 2px 10px;
        border: 1px solid {{ section.settings.border_soft_color }};
        border-radius: 999px;
        text-align: center;
        font-size: 14px;
        font-family: 'Circular';
        font-weight: 700;
        line-height: 1.2;
        background: {{ section.settings.badge_bg }};
      }

      #{{ section_id }} .os-reviews-summary__cta {
        display: flex;
        justify-content: center;
        align-items: center;
      }

      #{{ section_id }} .os-reviews-write-btn,
      #{{ section_id }} .os-reviews-submit-btn,
      #{{ section_id }} .os-upload-btn {
        border: 0;
        cursor: pointer;
        transition: all .24s ease;
        font: inherit;
      }
      .upload-text{
            color: #fff;
      }

      #{{ section_id }} .os-reviews-write-btn {
        background: {{ section.settings.button_bg }};
        color: {{ section.settings.button_text }};
        min-width: 170px;
        min-height: 48px;
        border-radius: {{ section.settings.button_radius }}px;
        font-size: 16px;
        font-family: 'Circular';
        font-weight: 400;
        padding: 6px 20px;
      }

      #{{ section_id }} .os-reviews-write-btn:hover,
      #{{ section_id }} .os-reviews-submit-btn:hover,
      #{{ section_id }} .os-upload-btn:hover {
        opacity: .88;
        transform: translateY(-1px);
      }

      #{{ section_id }} .os-reviews-form-wrap {
        overflow: hidden;
        max-height: 0;
        opacity: 0;
