  </style>

  <script>
    (() => {
      const section = document.getElementById('{{ section_id }}');
      if (!section) return;

      const reviewToggle = section.querySelector('[data-review-toggle]');
      const reviewFormWrap = section.querySelector('.os-reviews-form-wrap');
      const reviewForm = section.querySelector('[data-review-form]');
      const successMessage = section.querySelector('[data-review-success]');
      const submitBtn = section.querySelector('[data-submit-btn]');
      const processingBox = section.querySelector('[data-review-processing]');
      const processingDelay = {{ section.settings.processing_seconds | times: 1000 | json }};

      if (reviewToggle && reviewFormWrap) {
        reviewToggle.addEventListener('click', () => {
          const isOpen = reviewFormWrap.classList.contains('is-open');

          if (isOpen) {
            reviewFormWrap.classList.remove('is-open');
            reviewToggle.setAttribute('aria-expanded', 'false');

            setTimeout(() => {
              reviewFormWrap.hidden = true;
            }, 420);
          } else {
            reviewFormWrap.hidden = false;
            requestAnimationFrame(() => {
              reviewFormWrap.classList.add('is-open');
              reviewToggle.setAttribute('aria-expanded', 'true');
            });
          }
        });
      }

      const ratingWrap = section.querySelector('[data-rating-input]');
      if (ratingWrap) {
        const stars = ratingWrap.querySelectorAll('.os-review-rating-input__star');
        const text = ratingWrap.querySelector('[data-rating-text]');
        let selected = 0;

       const paintStars = (value) => {
        stars.forEach((star, index) => {
            star.classList.toggle('is-active', index < value);
        });
        if (text) text.textContent = `${value}/5`;
        };

        stars.forEach((star) => {
          star.addEventListener('mouseenter', () => {
            paintStars(Number(star.dataset.value));
          });

          star.addEventListener('click', () => {
            selected = Number(star.dataset.value);
            paintStars(selected);
          });
        });

        ratingWrap.addEventListener('mouseleave', () => {
          paintStars(selected);
        });
      }
      if (reviewForm && reviewFormWrap) {
        reviewForm.addEventListener('submit', (event) => {
            event.preventDefault();

            if (submitBtn) {
            submitBtn.disabled = true;
            }

            if (processingBox) {
            processingBox.hidden = false;
            }

            setTimeout(() => {
            if (successMessage) {
                successMessage.hidden = false;
            }

            reviewFormWrap.classList.remove('is-open');

            if (reviewToggle) {
                reviewToggle.setAttribute('aria-expanded', 'false');
            }

            setTimeout(() => {
                reviewFormWrap.hidden = true;
                reviewForm.reset();

                const stars = section.querySelectorAll('.os-review-rating-input__star');
                const ratingText = section.querySelector('[data-rating-text]');

              if (stars.length) {
                stars.forEach((star) => {
                    star.classList.remove('is-active');
                });
                }

                if (ratingText) {
                ratingText.textContent = '0/5';
                }

                if (processingBox) {
                processingBox.hidden = true;
                }

                if (submitBtn) {
                submitBtn.disabled = false;
                }

                if (successMessage) {
                successMessage.scrollIntoView({
                    behavior: 'smooth',
                    block: 'nearest'
                });
                }
            }, 420);
            }, processingDelay);
        });
        }

      const dropdown = section.querySelector('[data-sort-dropdown]');
      const dropdownToggle = section.querySelector('[data-sort-toggle]');
      const dropdownMenu = section.querySelector('[data-sort-menu]');
      const sortOptions = section.querySelectorAll('.os-reviews-sort__option');
      const reviewsList = section.querySelector('[data-reviews-list]');
      const reviewCards = Array.from(section.querySelectorAll('[data-review-card]'));
      const pagination = section.querySelector('[data-pagination]');
      const perPage = {{ reviews_per_page | json }};

      let currentSort = 'recent';
      let currentPage = 1;

      function getSortedCards() {
        const cards = [...reviewCards];

        if (currentSort === 'highest') {
          cards.sort((a, b) => Number(b.dataset.rating) - Number(a.dataset.rating));
        } else if (currentSort === 'lowest') {
          cards.sort((a, b) => Number(a.dataset.rating) - Number(b.dataset.rating));
        } else if (currentSort === 'photos') {
          return cards.filter(card => card.dataset.hasPhoto === 'true');
        } else {
          cards.sort((a, b) => Number(b.dataset.timestamp || 0) - Number(a.dataset.timestamp || 0));
        }

        return cards;
      }

      function renderPagination(totalPages) {
        if (!pagination) return;
        pagination.innerHTML = '';

        if (totalPages <= 1) return;

        const prevBtn = document.createElement('button');
        prevBtn.type = 'button';
        prevBtn.textContent = '«';
        prevBtn.disabled = currentPage === 1;
        prevBtn.addEventListener('click', () => {
          if (currentPage > 1) {
            currentPage--;
            renderReviews();
          }
        });
        pagination.appendChild(prevBtn);

        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = i;
          if (i === currentPage) btn.classList.add('is-active');

          btn.addEventListener('click', () => {
            currentPage = i;
            renderReviews();
          });

          pagination.appendChild(btn);
        }

        const nextBtn = document.createElement('button');
        nextBtn.type = 'button';
        nextBtn.textContent = '»';
        nextBtn.disabled = currentPage === totalPages;
        nextBtn.addEventListener('click', () => {
          if (currentPage < totalPages) {
            currentPage++;
            renderReviews();
          }
        });
        pagination.appendChild(nextBtn);
      }

      function renderReviews() {
        const sorted = getSortedCards();

        reviewCards.forEach(card => {
          card.classList.remove('is-visible');
        });

        if (!sorted.length) {
          if (pagination) pagination.innerHTML = '';
          return;
        }

        sorted.forEach(card => reviewsList.appendChild(card));

        const totalPages = Math.ceil(sorted.length / perPage);
        if (currentPage > totalPages) currentPage = 1;

        const start = (currentPage - 1) * perPage;
        const end = start + perPage;

        sorted.slice(start, end).forEach(card => {
          card.classList.add('is-visible');
        });

        renderPagination(totalPages);
      }

      if (dropdown && dropdownToggle && dropdownMenu) {
        dropdownToggle.addEventListener('click', () => {
          const isOpen = dropdown.classList.contains('is-open');
          dropdown.classList.toggle('is-open', !isOpen);
          dropdownToggle.setAttribute('aria-expanded', String(!isOpen));
          dropdownMenu.hidden = isOpen;
        });

        document.addEventListener('click', (event) => {
          if (!dropdown.contains(event.target)) {
            dropdown.classList.remove('is-open');
            dropdownToggle.setAttribute('aria-expanded', 'false');
            dropdownMenu.hidden = true;
          }
        });

        sortOptions.forEach(option => {
          option.addEventListener('click', () => {
            sortOptions.forEach(opt => opt.classList.remove('is-active'));
            option.classList.add('is-active');

            currentSort = option.dataset.sort;
            currentPage = 1;
            renderReviews();

            dropdown.classList.remove('is-open');
            dropdownToggle.setAttribute('aria-expanded', 'false');
            dropdownMenu.hidden = true;
          });
        });
      }

      renderReviews();
    })();
  </script>

