{% liquid
  assign section_id = 'os-best-sellers-collection-' | append: section.id
  assign selected_collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign featured_product = section.settings.featured_product
%}

<section id="{{ section_id }}" class="os-bsc">
  <div class="os-bsc__container{% if section.settings.full_width %} os-bsc__container--full{% endif %}">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="os-bsc__header">
        {% if section.settings.heading != blank %}
          <h2 class="os-bsc__title">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="os-bsc__subtitle">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if selected_collection != blank and selected_collection.products_count > 0 %}
      <div class="os-bsc__grid">
        {% assign normal_count = 0 %}
        {% for product in selected_collection.products %}
          {% if featured_product != blank and product.id == featured_product.id %}
            {% continue %}
          {% endif %}

          {% if normal_count < 3 %}
            {% liquid
              assign matched_swatch_block = blank
              for block in section.blocks
                if block.type == 'product_swatches'
                  if block.settings.product != blank and block.settings.product.id == product.id
                    assign matched_swatch_block = block
                    break
                  endif
                endif
              endfor

              assign has_product_swatches = false
              if matched_swatch_block != blank
                for i in (1..12)
                  assign swatch_key = 'swatch_' | append: i
                  assign swatch_image = matched_swatch_block.settings[swatch_key]
                  if swatch_image != blank
                    assign has_product_swatches = true
                    break
                  endif
                endfor
              endif
            %}

            <div class="os-bsc__item">
              <article class="os-bsc__card{% if has_product_swatches %} has-swatches{% endif %}">
                <div class="os-bsc__media">
                  {% if section.settings.show_sold_out_badge and product.available == false %}
                    <span class="os-bsc__badge">{{ section.settings.sold_out_text }}</span>
                  {% endif %}

                  <a href="{{ product.url }}" class="os-bsc__media-link" aria-label="{{ product.title | escape }}">
                    {% if product.featured_image != blank %}
                      {{
                        product.featured_image
                        | image_url: width: 900
                        | image_tag:
                          class: 'os-bsc__image',
                          loading: 'lazy',
                          widths: '240,360,480,720,900',
                          alt: product.featured_image.alt
                      }}
                    {% else %}
                      <div class="os-bsc__image-placeholder"></div>
                    {% endif %}
                  </a>

                  {% if has_product_swatches %}
                    <div class="os-bsc__swatches-row">
                      <div class="os-bsc__swatches" {{ matched_swatch_block.shopify_attributes }}>
                        {% assign swatch_total = 0 %}
                        {% for i in (1..12) %}
                          {% liquid
                            assign swatch_key = 'swatch_' | append: i
                            assign swatch_image = matched_swatch_block.settings[swatch_key]
                            if swatch_image != blank
                              assign swatch_total = swatch_total | plus: 1
                            endif
                          %}
                        {% endfor %}

                        {% for i in (1..5) %}
                          {% liquid
                            assign swatch_key = 'swatch_' | append: i
                            assign swatch_image = matched_swatch_block.settings[swatch_key]

                            assign swatch_product_key = 'swatch_product_' | append: i
                            assign swatch_product = matched_swatch_block.settings[swatch_product_key]

                            assign swatch_link_key = 'swatch_link_' | append: i
                            assign swatch_link = matched_swatch_block.settings[swatch_link_key]

                            assign final_swatch_url = blank
                            if swatch_product != blank
                              assign final_swatch_url = swatch_product.url
                            elsif swatch_link != blank
                              assign final_swatch_url = swatch_link
                            endif
                          %}
                          {% if swatch_image != blank %}
                            {% if final_swatch_url != blank %}
                              <a
                                href="{{ final_swatch_url }}"
                                class="os-bsc__swatch-link"
                                aria-label="{{ product.title | escape }}"
                              >
                                <span class="os-bsc__swatch">
                                  {{
                                    swatch_image
                                    | image_url: width: 60
                                    | image_tag:
                                      class: 'os-bsc__swatch-image',
                                      loading: 'lazy',
                                      widths: '30,40,60',
                                      alt: product.title
                                  }}
                                </span>
                              </a>
                            {% else %}
                              <span class="os-bsc__swatch">
                                {{
                                  swatch_image
                                  | image_url: width: 60
                                  | image_tag:
                                    class: 'os-bsc__swatch-image',
                                    loading: 'lazy',
                                    widths: '30,40,60',
                                    alt: product.title
                                }}
                              </span>
                            {% endif %}
                          {% endif %}
                        {% endfor %}

                        {% if swatch_total > 5 %}
                          <a
                            href="{{ product.url }}"
                            class="os-bsc__swatch-link os-bsc__swatch-count-link"
                            aria-label="Ver {{ product.title | escape }}"
                          >
                            <span class="os-bsc__swatch-count">+{{ swatch_total | minus: 5 }}</span>
                          </a>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                </div>

                <div class="os-bsc__content">
                  <h3 class="os-bsc__product-title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>

                  <div class="os-bsc__price">
                    <span class="os-bsc__price-current">{{ product.price | money }}</span>
                  </div>

                  <div class="os-bsc__actions">
                    {% if show_featured_view_button %}
                      <a href="{{ featured_product.url }}" class="os-bsc__button os-bsc__button--view">
                        {{ section.settings.view_more_text }}
                      </a>
                    {% elsif featured_product.available %}
                      <button
                        type="button"
                        class="os-bsc__button os-bsc__button--add"
                        data-os-add
                        data-variant-id="{{ featured_product.selected_or_first_available_variant.id }}"
                        data-added-text="{{ section.settings.added_text }}"
                        data-adding-text="{{ section.settings.adding_text }}"
                      >
                        {{ section.settings.add_to_cart_text }}
                      </button>
                    {% else %}
                      <span class="os-bsc__button os-bsc__button--soldout is-disabled">
                        {{ section.settings.sold_out_button_text }}
                      </span>
                    {% endif %}
                  </div>
                </div>
              </article>
            </div>

            {% assign normal_count = normal_count | plus: 1 %}
          {% endif %}
        {% endfor %}

        {% if featured_product != blank %}
          {% liquid
            assign matched_swatch_block = blank
            for block in section.blocks
              if block.type == 'product_swatches'
                if block.settings.product != blank and block.settings.product.id == featured_product.id
                  assign matched_swatch_block = block
                  break
                endif
              endif
            endfor

            assign has_featured_swatches = false
            assign show_featured_view_button = false

            if matched_swatch_block != blank
              if matched_swatch_block.settings.invisible_view_more_trigger
                assign show_featured_view_button = true
              endif

              for i in (1..12)
                assign swatch_key = 'swatch_' | append: i
                assign swatch_image = matched_swatch_block.settings[swatch_key]
                if swatch_image != blank
                  assign has_featured_swatches = true
                  assign show_featured_view_button = true
                  break
                endif
              endfor
            endif
          %}

          <div class="os-bsc__item os-bsc__item--featured">
            <article class="os-bsc__card os-bsc__card--featured{% if has_featured_swatches %} has-swatches{% endif %}">
              <div class="os-bsc__media os-bsc__media--featured">
                {% if section.settings.show_sold_out_badge and featured_product.available == false %}
                  <span class="os-bsc__badge">{{ section.settings.sold_out_text }}</span>
                {% endif %}

                <a
                  href="{{ featured_product.url }}"
                  class="os-bsc__media-link"
                  aria-label="{{ featured_product.title | escape }}"
                >
                  {% if featured_product.featured_image != blank %}
                    {{
                      featured_product.featured_image
                      | image_url: width: 1400
                      | image_tag:
                        class: 'os-bsc__image os-bsc__image--featured',
                        loading: 'lazy',
                        widths: '480,720,900,1200,1400',
                        alt: featured_product.featured_image.alt
                    }}
                  {% else %}
                    <div class="os-bsc__image-placeholder"></div>
                  {% endif %}
                </a>

                {% if has_featured_swatches %}
                  <div class="os-bsc__swatches-row os-bsc__swatches-row--featured">
                    <div class="os-bsc__swatches" {{ matched_swatch_block.shopify_attributes }}>
                      {% assign swatch_total = 0 %}
                      {% for i in (1..12) %}
                        {% liquid
                          assign swatch_key = 'swatch_' | append: i
                          assign swatch_image = matched_swatch_block.settings[swatch_key]
                          if swatch_image != blank
                            assign swatch_total = swatch_total | plus: 1
                          endif
                        %}
                      {% endfor %}

                      {% for i in (1..5) %}
                        {% liquid
                          assign swatch_key = 'swatch_' | append: i
                          assign swatch_image = matched_swatch_block.settings[swatch_key]

                          assign swatch_product_key = 'swatch_product_' | append: i
                          assign swatch_product = matched_swatch_block.settings[swatch_product_key]

                          assign swatch_link_key = 'swatch_link_' | append: i
                          assign swatch_link = matched_swatch_block.settings[swatch_link_key]

                          assign final_swatch_url = blank
                          if swatch_product != blank
                            assign final_swatch_url = swatch_product.url
                          elsif swatch_link != blank
                            assign final_swatch_url = swatch_link
                          endif
                        %}
                        {% if swatch_image != blank %}
                          {% if final_swatch_url != blank %}
                            <a
                              href="{{ final_swatch_url }}"
                              class="os-bsc__swatch-link"
                              aria-label="{{ featured_product.title | escape }}"
                            >
                              <span class="os-bsc__swatch">
                                {{
                                  swatch_image
                                  | image_url: width: 60
                                  | image_tag:
                                    class: 'os-bsc__swatch-image',
                                    loading: 'lazy',
                                    widths: '30,40,60',
                                    alt: featured_product.title
                                }}
                              </span>
                            </a>
                          {% else %}
                            <span class="os-bsc__swatch">
                              {{
                                swatch_image
                                | image_url: width: 60
                                | image_tag:
                                  class: 'os-bsc__swatch-image',
                                  loading: 'lazy',
                                  widths: '30,40,60',
                                  alt: featured_product.title
                              }}
                            </span>
                          {% endif %}
                        {% endif %}
                      {% endfor %}

                      {% if swatch_total > 5 %}
                        <a
                          href="{{ featured_product.url }}"
                          class="os-bsc__swatch-link os-bsc__swatch-count-link"
                          aria-label="Ver {{ featured_product.title | escape }}"
                        >
                          <span class="os-bsc__swatch-count">+{{ swatch_total | minus: 5 }}</span>
                        </a>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              </div>

              <div class="os-bsc__content os-bsc__content--featured">
                <h3 class="os-bsc__product-title os-bsc__product-title--featured">
                  <a href="{{ featured_product.url }}">{{ featured_product.title }}</a>
                </h3>

                <div class="os-bsc__price">
                  <span class="os-bsc__price-current">{{ featured_product.price | money }}</span>
                </div>

                <div class="os-bsc__actions">
                  {% if show_featured_view_button %}
                    <a href="{{ featured_product.url }}" class="os-bsc__button os-bsc__button--view">
                      {{ section.settings.view_more_text }}
                    </a>
                  {% elsif featured_product.available %}
                    <button
                      type="button"
                      class="os-bsc__button os-bsc__button--add"
                      data-os-add
                      data-variant-id="{{ featured_product.selected_or_first_available_variant.id }}"
                      data-added-text="{{ section.settings.added_text }}"
                      data-adding-text="{{ section.settings.adding_text }}"
                    >
                      {{ section.settings.add_to_cart_text }}
                    </button>
                  {% else %}
                    <span class="os-bsc__button os-bsc__button--soldout is-disabled">
                      {{ section.settings.sold_out_button_text }}
                    </span>
                  {% endif %}
                </div>
              </div>
            </article>
          </div>
        {% endif %}

        {% assign rendered_more = 0 %}
        {% for product in selected_collection.products %}
          {% if featured_product != blank and product.id == featured_product.id %}
            {% continue %}
          {% endif %}

          {% assign skip_product = false %}
          {% assign count_index = 0 %}
          {% for first_product in selected_collection.products %}
            {% if featured_product != blank and first_product.id == featured_product.id %}
              {% continue %}
            {% endif %}
            {% if count_index < 3 and first_product.id == product.id %}
              {% assign skip_product = true %}
            {% endif %}
            {% if count_index < 3 %}
              {% assign count_index = count_index | plus: 1 %}
            {% endif %}
          {% endfor %}

          {% if skip_product %}
            {% continue %}
          {% endif %}

          {% if rendered_more < products_to_show %}
            {% liquid
              assign matched_swatch_block = blank
              for block in section.blocks
                if block.type == 'product_swatches'
                  if block.settings.product != blank and block.settings.product.id == product.id
                    assign matched_swatch_block = block
                    break
                  endif
                endif
              endfor

              assign has_product_swatches = false
              if matched_swatch_block != blank
                for i in (1..12)
                  assign swatch_key = 'swatch_' | append: i
                  assign swatch_image = matched_swatch_block.settings[swatch_key]
                  if swatch_image != blank
                    assign has_product_swatches = true
                    break
                  endif
                endfor
              endif
            %}

            <div class="os-bsc__item">
              <article class="os-bsc__card{% if has_product_swatches %} has-swatches{% endif %}">
                <div class="os-bsc__media">
                  {% if section.settings.show_sold_out_badge and product.available == false %}
                    <span class="os-bsc__badge">{{ section.settings.sold_out_text }}</span>
                  {% endif %}

                  <a href="{{ product.url }}" class="os-bsc__media-link" aria-label="{{ product.title | escape }}">
                    {% if product.featured_image != blank %}
                      {{
                        product.featured_image
                        | image_url: width: 900
                        | image_tag:
                          class: 'os-bsc__image',
                          loading: 'lazy',
                          widths: '240,360,480,720,900',
                          alt: product.featured_image.alt
                      }}
                    {% else %}
                      <div class="os-bsc__image-placeholder"></div>
                    {% endif %}
                  </a>

                  {% if has_product_swatches %}
                    <div class="os-bsc__swatches-row">
                      <div class="os-bsc__swatches" {{ matched_swatch_block.shopify_attributes }}>
                        {% assign swatch_total = 0 %}
                        {% for i in (1..12) %}
                          {% liquid
                            assign swatch_key = 'swatch_' | append: i
                            assign swatch_image = matched_swatch_block.settings[swatch_key]
                            if swatch_image != blank
                              assign swatch_total = swatch_total | plus: 1
                            endif
                          %}
                        {% endfor %}

                        {% for i in (1..5) %}
                          {% liquid
                            assign swatch_key = 'swatch_' | append: i
                            assign swatch_image = matched_swatch_block.settings[swatch_key]

                            assign swatch_product_key = 'swatch_product_' | append: i
                            assign swatch_product = matched_swatch_block.settings[swatch_product_key]

                            assign swatch_link_key = 'swatch_link_' | append: i
                            assign swatch_link = matched_swatch_block.settings[swatch_link_key]

                            assign final_swatch_url = blank
                            if swatch_product != blank
                              assign final_swatch_url = swatch_product.url
                            elsif swatch_link != blank
                              assign final_swatch_url = swatch_link
                            endif
                          %}
                          {% if swatch_image != blank %}
                            {% if final_swatch_url != blank %}
                              <a
                                href="{{ final_swatch_url }}"
                                class="os-bsc__swatch-link"
                                aria-label="{{ product.title | escape }}"
                              >
                                <span class="os-bsc__swatch">
                                  {{
                                    swatch_image
                                    | image_url: width: 60
                                    | image_tag:
                                      class: 'os-bsc__swatch-image',
                                      loading: 'lazy',
                                      widths: '30,40,60',
                                      alt: product.title
                                  }}
                                </span>
                              </a>
                            {% else %}
                              <span class="os-bsc__swatch">
                                {{
                                  swatch_image
                                  | image_url: width: 60
                                  | image_tag:
                                    class: 'os-bsc__swatch-image',
                                    loading: 'lazy',
                                    widths: '30,40,60',
                                    alt: product.title
                                }}
                              </span>
                            {% endif %}
                          {% endif %}
                        {% endfor %}

                        {% if swatch_total > 5 %}
                          <a
                            href="{{ product.url }}"
                            class="os-bsc__swatch-link os-bsc__swatch-count-link"
                            aria-label="Ver {{ product.title | escape }}"
                          >
                            <span class="os-bsc__swatch-count">+{{ swatch_total | minus: 5 }}</span>
                          </a>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                </div>

                <div class="os-bsc__content">
                  <h3 class="os-bsc__product-title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>

                  <div class="os-bsc__price">
                    <span class="os-bsc__price-current">{{ product.price | money }}</span>
                  </div>

                  <div class="os-bsc__actions">
                    {% if has_product_swatches %}
                      <a href="{{ product.url }}" class="os-bsc__button os-bsc__button--view">
                        {{ section.settings.view_more_text }}
                      </a>
                    {% elsif product.available %}
                      <button
                        type="button"
                        class="os-bsc__button os-bsc__button--add"
                        data-os-add
                        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                        data-added-text="{{ section.settings.added_text }}"
                        data-adding-text="{{ section.settings.adding_text }}"
                      >
                        {{ section.settings.add_to_cart_text }}
                      </button>
                    {% else %}
                      <span class="os-bsc__button os-bsc__button--soldout is-disabled">
                        {{ section.settings.sold_out_button_text }}
                      </span>
                    {% endif %}
                  </div>
                </div>
              </article>
            </div>

            {% assign rendered_more = rendered_more | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="os-bsc__empty">Selecciona una colección para mostrar productos.</div>
    {% endif %}
  </div>

  <style>
                #{{ section_id }} {
                  --bg: {{ section.settings.section_bg }};
                  --card-bg: {{ section.settings.card_bg }};
                  --content-bg: {{ section.settings.content_bg }};
                  --title-color: {{ section.settings.title_color }};
                  --subtitle-color: {{ section.settings.subtitle_color }};
                  --product-title-color: {{ section.settings.product_title_color }};
                  --price-color: {{ section.settings.price_color }};
                  --badge-bg: {{ section.settings.badge_bg }};
                  --badge-color: {{ section.settings.badge_color }};
                  --add-btn-bg: {{ section.settings.add_button_bg }};
                  --add-btn-color: {{ section.settings.add_button_text }};
                  --view-btn-bg: {{ section.settings.view_button_bg }};
                  --view-btn-color: {{ section.settings.view_button_text }};
                  --soldout-btn-bg: {{ section.settings.sold_out_button_bg }};
                  --soldout-btn-color: {{ section.settings.sold_out_button_text_color }};
                  --card-radius: {{ section.settings.card_radius }}px;
                  --card-gap: {{ section.settings.card_gap }}px;
                  --section-padding-top: {{ section.settings.padding_top }}px;
                  --section-padding-bottom: {{ section.settings.padding_bottom }}px;
                 --media-height: {{ section.settings.image_height_desktop }}px;
                    --media-height-mobile: {{ section.settings.image_height_mobile }}px;
                    --featured-media-height: {{ section.settings.image_height_desktop }}px;
                    --featured-media-height-mobile: {{ section.settings.featured_image_height_mobile }}px;
                }

                #{{ section_id }}.os-bsc {
                  background: var(--bg);
                  padding-top: var(--section-padding-top);
                  padding-bottom: var(--section-padding-bottom);
                }

               #{{ section_id }} .os-bsc__container {
                    max-width: 1320px;
                    margin: 0 auto;
                    padding: 0 24px;
                    }

                #{{ section_id }} .os-bsc__container--full {
                  max-width: 100%;
                  padding-left: 20px;
                  padding-right: 20px;
                }

                #{{ section_id }} .os-bsc__header {
                  text-align: center;
                  margin: 0 0 30px;
                }

                #{{ section_id }} .os-bsc__title {
                  margin: 0 0 10px;
                  color: var(--title-color);
                  font-size: {{ section.settings.heading_size }}px;
                  line-height: 1.12;
                  font-weight: 500;
                  letter-spacing: 0;
                }

                #{{ section_id }} .os-bsc__subtitle {
                  margin: 0;
                  color: var(--subtitle-color);
                  font-size: {{ section.settings.subheading_size }}px;
                  line-height: 1.45;
                }

                #{{ section_id }} .os-bsc__grid {
                            display: grid;
                            grid-template-columns: repeat(3, minmax(0, 1fr));
                            gap: 12px;
                            align-items: start;
                 }

                #{{ section_id }} .os-bsc__item {
                  min-width: 0;
                }

                #{{ section_id }} .os-bsc__item--featured {
                    grid-column: span 2;
                    grid-row: auto;
                }

                #{{ section_id }} .os-bsc__card {
                  display: flex;
                  flex-direction: column;
                  height: 100%;
                  background: transparent;
                }

              #{{ section_id }} .os-bsc__media {
                position: relative;
                background: var(--card-bg);
                border-radius: var(--card-radius) var(--card-radius) 0 0;
                overflow: hidden;
                display: block;
                line-height: 0;
                height: var(--media-height);
                }

                #{{ section_id }} .os-bsc__media--featured {
                height: var(--featured-media-height);
                }

                #{{ section_id }} .os-bsc__media-link {
                display: block;
                width: 100%;
                height: 100%;
                text-decoration: none;
                }

                #{{ section_id }} .os-bsc__image {
                width: 100%;
                height: 100%;
                display: block;
                object-fit: cover;
                object-position: center;
                }
               #{{ section_id }} .os-bsc__media {
                    overflow: hidden;
                    }

                    #{{ section_id }} .os-bsc__image,
                    #{{ section_id }} .os-bsc__image--featured {
                    transition: transform .45s ease;
                    will-change: transform;
                    }

                    #{{ section_id }} .os-bsc__card:hover .os-bsc__image,
                    #{{ section_id }} .os-bsc__card:hover .os-bsc__image--featured {
                    transform: scale(1.04);
                    }
                #{{ section_id }} .os-bsc__image--featured {
                width: 100%;
                height: 100%;
                display: block;
                object-fit: cover;
                object-position: center;
                }
                #{{ section_id }} .os-bsc__image-placeholder {
                  width: 100%;
                  height: 100%;
                  min-height: inherit;
                  background: rgba(0,0,0,0.05);
                }

                #{{ section_id }} .os-bsc__badge {
                 position: absolute;
                top: 8px;
                left: 8px;
                z-index: 1;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: var(--badge-bg);
                color: var(--badge-color);
                font-size: 12.6px;
                line-height: 1;
                /* border-radius: 3px; */
                font-weight: 600;
                font-family: 'Circular';
                padding: 6px 8px;
                border-radius: 3px;
                text-transform: uppercase;
