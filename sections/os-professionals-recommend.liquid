{% liquid
  assign section_id = 'os-professionals-recommend-' | append: section.id
  assign professional_blocks = section.blocks | where: 'type', 'professional'
  assign logo_blocks = section.blocks | where: 'type', 'logo'
%}

<section id="{{ section_id }}" class="os-professionals">
  <div class="os-professionals__inner {% if section.settings.section_width == 'page' %}page-width{% endif %}">
    <div class="os-professionals__header">
      <div class="os-professionals__header-left">
        {% if section.settings.heading != blank %}
          <h2 class="os-professionals__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>

      {% if logo_blocks.size > 0 %}
        <div class="os-professionals__header-right os-professionals__desktop-logos">
          <div class="os-professionals__logos">
            {% for block in section.blocks %}
              {% if block.type == 'logo' %}
                <div class="os-professionals__logo-item" {{ block.shopify_attributes }}>
                  {% if block.settings.logo != blank %}
                    <img
                      src="{{ block.settings.logo | image_url: width: 400 }}"
                      alt="{{ block.settings.alt | escape }}"
                      width="{{ block.settings.logo.width }}"
                      height="{{ block.settings.logo.height }}"
                      loading="lazy"
                    >
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    {% if professional_blocks.size > 0 %}
      <div class="os-professionals__slider-wrap">
        <div class="os-professionals__viewport" data-viewport>
          <div class="os-professionals__track" data-track>
            {% for block in section.blocks %}
              {% if block.type == 'professional' %}
                <article class="os-professionals__card" {{ block.shopify_attributes }}>
                  <div class="os-professionals__media">
                    {% if block.settings.image != blank %}
                      <img
                        src="{{ block.settings.image | image_url: width: 1000 }}"
                        alt="{{ block.settings.name | escape }}"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                        loading="lazy"
                      >
                    {% else %}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </div>

                  <div class="os-professionals__content">
                    {% if block.settings.quote != blank %}
                      <div class="os-professionals__quote">
                        {{ block.settings.quote }}
                      </div>
                    {% endif %}

                    {% if block.settings.name != blank %}
                      <div class="os-professionals__name-row">
                        <h3 class="os-professionals__name">{{ block.settings.name }}</h3>

                        {% if block.settings.show_verified %}
                          <span class="os-professionals__verified" aria-hidden="true">
                            <img
                              src="{{ 'verificado.svg' | asset_url }}"
                              alt=""
                              loading="lazy"
                              width="20"
                              height="20"
                            >
                          </span>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% if block.settings.role != blank %}
                      <div class="os-professionals__role">{{ block.settings.role }}</div>
                    {% endif %}
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if logo_blocks.size > 0 %}
          <div class="os-professionals__mobile-bottom">
            <div class="os-professionals__mobile-logos">
              {% for block in section.blocks %}
                {% if block.type == 'logo' %}
                  <div class="os-professionals__logo-item" {{ block.shopify_attributes }}>
                    {% if block.settings.logo != blank %}
                      <img
                        src="{{ block.settings.logo | image_url: width: 400 }}"
                        alt="{{ block.settings.alt | escape }}"
                        width="{{ block.settings.logo.width }}"
                        height="{{ block.settings.logo.height }}"
                        loading="lazy"
                      >
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            <div class="os-professionals__mobile-progress" data-progress-wrap aria-hidden="true">
              <div class="os-professionals__mobile-progress-track"></div>
              <div class="os-professionals__mobile-progress-thumb" data-progress-thumb></div>
            </div>
          </div>
        {% endif %}
    {% endif %}
  </div>
</section>

<style>
  @font-face {
    font-family: 'Pulp';
    src: url('{{ 'Pulp.woff2' | asset_url }}') format('woff2');
    font-weight: 800;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Circular Custom';
    src: url('{{ 'Delamere W01 Bold.woff' | asset_url }}') format('woff');
    font-weight: 800;
    font-style: normal;
    font-display: swap;
  }

  #{{ section_id }} .os-professionals__heading,
  #{{ section_id }} .os-professionals__quote,
  #{{ section_id }} .os-professionals__name,
  #{{ section_id }} .os-professionals__role,
  #{{ section_id }} .os-professionals__logo-item,
  #{{ section_id }} p,
  #{{ section_id }} h2,
  #{{ section_id }} h3,
  #{{ section_id }} span,
  #{{ section_id }} div {
    letter-spacing: normal;
  }

  #{{ section_id }} {
    --os-bg: {{ section.settings.bg_color }};
    --os-text: {{ section.settings.text_color }};
    --os-muted: {{ section.settings.muted_color }};
    --os-heading: {{ section.settings.heading_color }};
    --os-progress-track: {{ section.settings.progress_track_color }};
    --os-progress-thumb: {{ section.settings.progress_thumb_color }};
    --os-card-radius: {{ section.settings.card_radius }}px;
    --os-image-radius: {{ section.settings.image_radius }}px;
    --os-section-pad-top: {{ section.settings.padding_top }}px;
    --os-section-pad-bottom: {{ section.settings.padding_bottom }}px;
    --os-image-position: {{ section.settings.image_position }};
    --os-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --os-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --os-quote-size-desktop: {{ section.settings.quote_size_desktop }}px;
    --os-quote-size-mobile: {{ section.settings.quote_size_mobile }}px;
    --os-name-size-desktop: {{ section.settings.name_size_desktop }}px;
    --os-name-size-mobile: {{ section.settings.name_size_mobile }}px;
    --os-role-size-desktop: {{ section.settings.role_size_desktop }}px;
    --os-role-size-mobile: {{ section.settings.role_size_mobile }}px;
    background: var(--os-bg);
    color: var(--os-text);
  }

  #{{ section_id }} .os-professionals__inner {
    width: 100%;
    max-width: {% if section.settings.section_width == 'custom' %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ section.settings.side_padding_desktop }}px;
    padding-right: {{ section.settings.side_padding_desktop }}px;
    padding-top: var(--os-section-pad-top);
    padding-bottom: var(--os-section-pad-bottom);
  }

  #{{ section_id }} .os-professionals__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
    margin-bottom: 1.4rem;
  }

  #{{ section_id }} .os-professionals__header-left {
    flex: 0 0 auto;
  }

  #{{ section_id }} .os-professionals__header-right {
    flex: 1 1 auto;
    display: flex;
    justify-content: flex-end;
  }

  #{{ section_id }} .os-professionals__heading {
    margin: 0;
    color: var(--os-heading);
    font-size: var(--os-heading-size-desktop);
    letter-spacing: normal;
    font-weight: 600;
    font-family: 'Pulp', Helvetica, Arial, sans-serif;
    line-height: 1.08;
  }

  #{{ section_id }} .os-professionals__logos {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2.2rem;
    flex-wrap: wrap;
    max-width: 100%;
  }

  #{{ section_id }} .os-professionals__logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: .95;
  }

  #{{ section_id }} .os-professionals__desktop-logos {
    display: flex;
  }

  #{{ section_id }} .os-professionals__mobile-bottom {
    display: none;
  }

  #{{ section_id }} .os-professionals__logo-item img {
    display: block;
    width: auto;
    height: auto;
    max-height: 4.4rem;
    max-width: 14rem;
    object-fit: contain;
  }

  #{{ section_id }} .os-professionals__slider-wrap {
    position: relative;
    margin-top: 0;
  }

  #{{ section_id }} .os-professionals__viewport {
    overflow: visible;
  }

  #{{ section_id }} .os-professionals__track {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: {{ section.settings.desktop_gap }}px;
  }

  #{{ section_id }} .os-professionals__card {
    min-width: 0;
  }

  #{{ section_id }} .os-professionals__media {
    position: relative;
    overflow: hidden;
    border-radius: var(--os-image-radius);
    background: #f2f2f2;
    aspect-ratio: 1 / 1;
    margin-bottom: 1.6rem;
  }

  #{{ section_id }} .os-professionals__media img,
  #{{ section_id }} .os-professionals__media svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  #{{ section_id }} .os-professionals__content {
    padding-right: .6rem;
  }

  #{{ section_id }} .os-professionals__quote {
    margin: 0 0 1.6rem;
    font-size: var(--os-quote-size-desktop);
    line-height: 1.62;
    color: var(--os-text);
    letter-spacing: normal;
  }

  #{{ section_id }} .os-professionals__name-row {
    display: flex;
    align-items: center;
    gap: .8rem;
    margin-bottom: .6rem;
    flex-wrap: wrap;
  }

  #{{ section_id }} .os-professionals__name {
    margin: 0;
    font-size: var(--os-name-size-desktop);
    line-height: 1.2;
    font-weight: 600;
    color: var(--os-heading);
    letter-spacing: normal;
    font-family: Helvetica, Arial, sans-serif;
  }

  #{{ section_id }} .os-professionals__verified {
    display: inline-flex;
    width: 1.9rem;
    height: 1.9rem;
    flex: 0 0 auto;
    line-height: 0;
  }

  #{{ section_id }} .os-professionals__verified img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #{{ section_id }} .os-professionals__role {
    font-size:14px;
    line-height: 1.45;
    color: var(--os-muted);
    letter-spacing: normal;
  }

  #{{ section_id }} .os-professionals__mobile-progress {
    display: none;
  }

  #{{ section_id }} .os-professionals__mobile-progress-track,
  #{{ section_id }} .os-professionals__mobile-progress-thumb {
    display: none;
  }

  @media screen and (max-width: 989px) {
    #{{ section_id }} .os-professionals__inner {
      padding-left: 16px;
      padding-right: {{ section.settings.side_padding_mobile }}px;
    }

    #{{ section_id }} .os-professionals__header {
      display: block;
      margin-bottom: 1.6rem;
    }

    #{{ section_id }} .os-professionals__header-left {
      width: 100%;
    }

    #{{ section_id }} .os-professionals__heading {
      font-size: var(--os-heading-size-mobile);
      line-height: 1.1;
      margin: 0;
    }

    #{{ section_id }} .os-professionals__desktop-logos {
      display: none !important;
    }

    #{{ section_id }} .os-professionals__slider-wrap {
      margin-top: 0;
    }

    #{{ section_id }} .os-professionals__viewport {
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: .2rem;
    }

    #{{ section_id }} .os-professionals__viewport::-webkit-scrollbar {
      display: none;
    }

    #{{ section_id }} .os-professionals__track {
      display: flex;
      gap: {{ section.settings.mobile_gap }}px;
      width: max-content;
    }

    #{{ section_id }} .os-professionals__card {
      width: min(46vw, 24rem);
      flex: 0 0 auto;
      scroll-snap-align: start;
    }

    #{{ section_id }} .os-professionals__media {
      margin-bottom: 1.4rem;
    }

    #{{ section_id }} .os-professionals__quote {
      font-size: var(--os-quote-size-mobile);
      line-height: 1.7;
      margin-bottom: 1.4rem;
    }

    #{{ section_id }} .os-professionals__name {
      font-size: var(--os-name-size-mobile);
    }

    #{{ section_id }} .os-professionals__role {
      font-size: var(--os-role-size-mobile);
    }

    #{{ section_id }} .os-professionals__mobile-bottom {
      display: block;
      margin-top: 1.6rem;
    }

    #{{ section_id }} .os-professionals__mobile-logos {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1.8rem;
      flex-wrap: nowrap;
      margin-top: 0;
      margin-bottom: 1.2rem;
    }

    #{{ section_id }} .os-professionals__mobile-logos .os-professionals__logo-item {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #{{ section_id }} .os-professionals__mobile-logos .os-professionals__logo-item img {
      display: block;
      max-height: 50px;
      max-width: 14.5rem;
      width: auto;
      height: auto;
      object-fit: contain;
    }

    #{{ section_id }} .os-professionals__mobile-progress {
      position: relative;
      display: block;
      width: min(31rem, 82%);
      height: .4rem;
      margin: 0 auto;
    }

    #{{ section_id }} .os-professionals__mobile-progress-track,
    #{{ section_id }} .os-professionals__mobile-progress-thumb {
      display: block;
      border-radius: 999px;
    }

    #{{ section_id }} .os-professionals__mobile-progress-track {
      position: absolute;
      inset: 0;
      background: var(--os-progress-track);
    }

    #{{ section_id }} .os-professionals__mobile-progress-thumb {
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 0%;
        background: var(--os-progress-thumb);
        transition: width .32s cubic-bezier(.22, .61, .36, 1);
        will-change: width;
        }
     @media screen and (max-width: 989px) {
        #{{ section_id }} .os-professionals__card--clone {
            pointer-events: none;
        }
        }
  }
</style>

<script>
  (function () {
    const section = document.getElementById('{{ section_id }}');
    if (!section) return;

    const viewport = section.querySelector('[data-viewport]');
    const track = section.querySelector('[data-track]');
    const progressWrap = section.querySelector('[data-progress-wrap]');
    const thumb = section.querySelector('[data-progress-thumb]');

    if (!viewport || !track || !progressWrap || !thumb) return;

    const mobileMq = window.matchMedia('(max-width: 989px)');
    let cardsCloned = false;
    let isResetting = false;
    let restartTimer = null;

    const INITIAL_FILL_RATIO = 0.14;

    function getOriginalCards() {
      return Array.from(track.querySelectorAll('.os-professionals__card:not(.os-professionals__card--clone)'));
    }

    function setupMobileLoop() {
      if (!mobileMq.matches || cardsCloned) return;

      const originals = getOriginalCards();
      if (!originals.length) return;

      // Queremos 7 cards visuales:
      // 3 originales + 4 clones => 7 total
      const cloneOrder = [0, 1, 2, 0];

      cloneOrder.forEach((index) => {
        if (!originals[index]) return;
        const clone = originals[index].cloneNode(true);
        clone.classList.add('os-professionals__card--clone');
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
      });

      cardsCloned = true;
    }

    function cleanupDesktopLoop() {
      if (mobileMq.matches) return;

      const clones = track.querySelectorAll('.os-professionals__card--clone');
      clones.forEach((clone) => clone.remove());

      cardsCloned = false;
      isResetting = false;
      clearTimeout(restartTimer);
      viewport.scrollLeft = 0;
      thumb.style.width = '0%';
    }

    function getMaxScroll() {
      return Math.max(0, viewport.scrollWidth - viewport.clientWidth);
    }

    function updateProgress() {
      if (!mobileMq.matches) {
        thumb.style.width = '0%';
        return;
      }

      const maxScroll = getMaxScroll();

      if (maxScroll <= 0) {
        thumb.style.width = INITIAL_FILL_RATIO * 100 + '%';
        return;
      }

      let ratio = viewport.scrollLeft / maxScroll;
      if (ratio < 0) ratio = 0;
      if (ratio > 1) ratio = 1;

      // La barra ya arranca un poco llena en la primera
      const visualRatio = INITIAL_FILL_RATIO + (1 - INITIAL_FILL_RATIO) * ratio;
      thumb.style.width = visualRatio * 100 + '%';
    }

    function resetToStartSmooth() {
      if (isResetting) return;
      isResetting = true;

      viewport.scrollTo({
        left: 0,
        behavior: 'smooth',
      });

      // hacemos que la barra también vuelva elegante al valor inicial
      setTimeout(function () {
        thumb.style.width = INITIAL_FILL_RATIO * 100 + '%';
      }, 260);

      setTimeout(function () {
        isResetting = false;
        updateProgress();
      }, 700);
    }

    function maybeRestartAtEnd() {
      if (!mobileMq.matches || isResetting) return;

      const maxScroll = getMaxScroll();
      if (maxScroll <= 0) return;

      const remaining = maxScroll - viewport.scrollLeft;

      // detecta realmente el final del scroll
      if (remaining <= 8) {
        thumb.style.width = '100%';

        clearTimeout(restartTimer);
        restartTimer = setTimeout(function () {
          resetToStartSmooth();
        }, 420);
      }
    }

    let ticking = false;

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(function () {
          updateProgress();
          ticking = false;
        });
        ticking = true;
      }

      clearTimeout(restartTimer);
      maybeRestartAtEnd();
    }

    function init() {
      if (mobileMq.matches) {
        setupMobileLoop();
      } else {
        cleanupDesktopLoop();
      }

      if (mobileMq.matches && viewport.scrollLeft <= 2) {
        thumb.style.width = INITIAL_FILL_RATIO * 100 + '%';
      } else {
        updateProgress();
      }
    }

    viewport.addEventListener('scroll', onScroll, { passive: true });

    window.addEventListener('resize', function () {
      if (mobileMq.matches) {
        setupMobileLoop();
      } else {
        cleanupDesktopLoop();
      }

      if (mobileMq.matches && viewport.scrollLeft <= 2) {
        thumb.style.width = INITIAL_FILL_RATIO * 100 + '%';
      } else {
        updateProgress();
      }
    });

    window.addEventListener('load', init);

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      init();
    } else {
      document.addEventListener('DOMContentLoaded', init);
    }

    setTimeout(init, 250);
    setTimeout(init, 700);
  })();
</script>

{% schema %}
{
  "name": "OS Profesionales",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Recomendado por profesionales"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color título",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color texto",
      "default": "#222222"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 18,
      "max": 60,
      "step": 1,
      "default": 28,
      "label": "Tamaño título desktop"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 42,
      "step": 1,
      "default": 22,
      "label": "Tamaño título móvil"
    },
    {
      "type": "range",
      "id": "quote_size_desktop",
      "min": 12,
      "max": 30,
      "step": 1,
      "default": 16,
      "label": "Tamaño texto desktop"
    },
    {
      "type": "range",
      "id": "quote_size_mobile",
      "min": 11,
      "max": 24,
      "step": 1,
      "default": 14,
      "label": "Tamaño texto móvil"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho de sección",
      "default": "page",
      "options": [
        {
          "value": "full",
          "label": "Ancho completo"
        },
        {
          "value": "page",
          "label": "Ancho contenido"
        },
        {
          "value": "custom",
          "label": "Ancho personalizado"
        }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 900,
      "max": 1800,
      "step": 20,
      "default": 1400,
      "label": "Ancho máximo personalizado"
    },
    {
      "type": "range",
      "id": "side_padding_desktop",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 24,
      "label": "Padding lateral desktop"
    },
    {
      "type": "range",
      "id": "side_padding_mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 16,
      "label": "Padding lateral móvil"
    },
    {
      "type": "text",
      "id": "image_position",
      "label": "Posición de imagen",
      "default": "center top",
      "info": "Ejemplo: center top, center center, center 20%"
    },
    {
      "type": "range",
      "id": "name_size_desktop",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 17,
      "label": "Tamaño nombre desktop"
    },
    {
      "type": "range",
      "id": "name_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 15,
      "label": "Tamaño nombre móvil"
    },
    {
      "type": "range",
      "id": "role_size_desktop",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14,
      "label": "Tamaño profesión desktop"
    },
    {
      "type": "range",
      "id": "role_size_mobile",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 13,
      "label": "Tamaño profesión móvil"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Color subtítulo/cargo",
      "default": "#6b6b6b"
    },
    {
      "type": "color",
      "id": "progress_track_color",
      "label": "Color barra base móvil",
      "default": "#d9d9d9"
    },
    {
      "type": "color",
      "id": "progress_thumb_color",
      "label": "Color barra activa móvil",
      "default": "#bdbdbd"
    },
    {
      "type": "range",
      "id": "desktop_gap",
      "min": 12,
      "max": 50,
      "step": 2,
      "default": 32,
      "label": "Separación desktop"
    },
