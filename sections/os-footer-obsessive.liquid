{% liquid
  assign section_id = 'os-footer-obsessive-' | append: section.id
%}

<footer id="{{ section_id }}" class="os-footer-obsessive">
  <div class="page-width">
    {% if request.page_type == 'index' %}
      {% if section.settings.top_follow_text != blank or section.settings.top_follow_handle != blank %}
        <div class="os-footer-obsessive__topline">
          {% if section.settings.top_follow_text != blank %}
            <span class="os-footer-obsessive__topline-label">{{ section.settings.top_follow_text }}</span>
          {% endif %}
          {% if section.settings.top_follow_handle != blank %}
            <a
              class="os-footer-obsessive__topline-handle"
              href="{{ section.settings.top_follow_link | default: '#' }}"
              {% if section.settings.top_follow_link != blank %}
                target="_blank" rel="noopener noreferrer"
              {% endif %}
            >
              {{ section.settings.top_follow_handle }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    <div class="os-footer-obsessive__newsletter">
      <div class="os-footer-obsessive__newsletter-grid">
        <div class="os-footer-obsessive__newsletter-col os-footer-obsessive__newsletter-col--title">
          {% if section.settings.newsletter_heading != blank %}
            <h2 class="os-footer-obsessive__newsletter-heading">
              {{ section.settings.newsletter_heading }}
            </h2>
          {% endif %}
        </div>

        <div class="os-footer-obsessive__newsletter-col os-footer-obsessive__newsletter-col--text">
          {% if section.settings.newsletter_text != blank %}
            <div class="os-footer-obsessive__newsletter-text rte">
              {{ section.settings.newsletter_text }}
            </div>
          {% endif %}
        </div>

        <div class="os-footer-obsessive__newsletter-col os-footer-obsessive__newsletter-col--form">
          {% form 'customer', class: 'os-footer-obsessive__form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">

            <div class="os-footer-obsessive__form-inner">
              <input
                type="email"
                name="contact[email]"
                class="os-footer-obsessive__input"
                value="{% if customer %}{{ customer.email }}{% endif %}"
                placeholder="{{ section.settings.newsletter_placeholder }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required
              >
              <button
                type="submit"
                class="os-footer-obsessive__submit"
                aria-label="{{ section.settings.newsletter_button_aria }}"
              >
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                  <path d="M5 12h13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M13 5l6 7-6 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            {% if form.posted_successfully? %}
              <div class="os-footer-obsessive__form-message os-footer-obsessive__form-message--success">
                <span class="os-footer-obsessive__form-success-icon" aria-hidden="true">
                  <svg aria-hidden="true" focusable="false" class="icon icon-success" viewBox="0 0 68 51">
                    <path d="M23.75 50.1042L0 26.3542L5.9375 20.4167L23.75 38.2292L61.9792 0L67.9167 5.9375L23.75 50.1042Z" fill="white"></path>
                  </svg>
                </span>
                <span>{{ section.settings.success_message }}</span>
              </div>
            {% endif %}

            {% if form.errors %}
              <div class="os-footer-obsessive__form-message os-footer-obsessive__form-message--error">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>

    <div class="os-footer-obsessive__links">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'menu_column' %}
            <div class="os-footer-obsessive__menu-col os-footer-obsessive__accordion" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="os-footer-obsessive__accordion-toggle"
                aria-expanded="false"
                aria-controls="FooterAccordion-{{ block.id }}"
              >
                <span class="os-footer-obsessive__accordion-title">
                  {{ block.settings.heading }}
                </span>
                <span class="os-footer-obsessive__accordion-icon" aria-hidden="true"></span>
              </button>

              {% assign menu_handle = block.settings.menu %}
              <div id="FooterAccordion-{{ block.id }}" class="os-footer-obsessive__accordion-content">
                {% if menu_handle != blank %}
                  <ul class="os-footer-obsessive__menu-list" role="list">
                    {% for link in linklists[menu_handle].links %}
                      <li class="os-footer-obsessive__menu-item">
                        <a href="{{ link.url }}" class="os-footer-obsessive__menu-link">
                          {{ link.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            </div>

          {% when 'social_column' %}
            <div class="os-footer-obsessive__menu-col os-footer-obsessive__accordion" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="os-footer-obsessive__accordion-toggle"
                aria-expanded="false"
                aria-controls="FooterAccordion-{{ block.id }}"
              >
                <span class="os-footer-obsessive__accordion-title">
                  {{ block.settings.heading }}
                </span>
                <span class="os-footer-obsessive__accordion-icon" aria-hidden="true"></span>
              </button>

              <div id="FooterAccordion-{{ block.id }}" class="os-footer-obsessive__accordion-content">
                <ul class="os-footer-obsessive__social-list" role="list">
                  {% if block.settings.instagram_label != blank %}
                    <li>
                      <a
                        href="{{ block.settings.instagram_link | default: '#' }}"
                        class="os-footer-obsessive__social-link"
                        {% if block.settings.instagram_link != blank %}
                          target="_blank" rel="noopener noreferrer"
                        {% endif %}
                      >
                        <span class="os-footer-obsessive__social-icon">
                          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <rect x="3.5" y="3.5" width="17" height="17" rx="4" stroke="currentColor" stroke-width="1.8"/>
                            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/>
                            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                          </svg>
                        </span>
                        <span>{{ block.settings.instagram_label }}</span>
                      </a>
                    </li>
                  {% endif %}

                  {% if block.settings.facebook_label != blank %}
                    <li>
                      <a
                        href="{{ block.settings.facebook_link | default: '#' }}"
                        class="os-footer-obsessive__social-link"
                        {% if block.settings.facebook_link != blank %}
                          target="_blank" rel="noopener noreferrer"
                        {% endif %}
                      >
                        <span class="os-footer-obsessive__social-icon">
                          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M13.5 21v-8h2.7l.4-3h-3.1V8.1c0-.9.3-1.6 1.6-1.6h1.7V3.8c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.5-4 4.2V10H8v3h2.4v8h3.1z"/>
                          </svg>
                        </span>
                        <span>{{ block.settings.facebook_label }}</span>
                      </a>
                    </li>
                  {% endif %}

                  {% if block.settings.youtube_label != blank %}
                    <li>
                      <a
                        href="{{ block.settings.youtube_link | default: '#' }}"
                        class="os-footer-obsessive__social-link"
                        {% if block.settings.youtube_link != blank %}
                          target="_blank" rel="noopener noreferrer"
                        {% endif %}
                      >
                        <span class="os-footer-obsessive__social-icon">
                          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M21.6 7.2a2.96 2.96 0 0 0-2.1-2.1C17.6 4.5 12 4.5 12 4.5s-5.6 0-7.5.6a2.96 2.96 0 0 0-2.1 2.1c-.6 1.9-.6 4.8-.6 4.8s0 2.9.6 4.8a2.96 2.96 0 0 0 2.1 2.1c1.9.6 7.5.6 7.5.6s5.6 0 7.5-.6a2.96 2.96 0 0 0 2.1-2.1c.6-1.9.6-4.8.6-4.8s0-2.9-.6-4.8ZM10 15.5v-7l6 3.5-6 3.5Z"/>
                          </svg>
                        </span>
                        <span>{{ block.settings.youtube_label }}</span>
                      </a>
                    </li>
                  {% endif %}

                  {% if block.settings.tiktok_label != blank %}
                    <li>
                      <a
                        href="{{ block.settings.tiktok_link | default: '#' }}"
                        class="os-footer-obsessive__social-link"
                        {% if block.settings.tiktok_link != blank %}
                          target="_blank" rel="noopener noreferrer"
                        {% endif %}
                      >
                        <span class="os-footer-obsessive__social-icon">
                          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M15.7 3c.3 2.3 1.6 4 3.8 4.5v3c-1.5 0-2.8-.4-4-1.2v5.5c0 3.8-2.4 6.2-6 6.2-3.2 0-5.5-2.3-5.5-5.3 0-3.2 2.5-5.5 5.8-5.5.3 0 .6 0 .9.1v3.1a3.7 3.7 0 0 0-.9-.1c-1.6 0-2.8 1-2.8 2.4 0 1.4 1.1 2.4 2.6 2.4 1.7 0 2.8-1.1 2.8-3.3V3h3.3Z"/>
                          </svg>
                        </span>
                        <span>{{ block.settings.tiktok_label }}</span>
                      </a>
                    </li>
                  {% endif %}
                </ul>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>

  <div class="os-footer-obsessive__bottom">
    <div class="page-width">
      <div class="os-footer-obsessive__bottom-top">
        <div class="os-footer-obsessive__payments">
          {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
            {% for type in shop.enabled_payment_types %}
              <span class="os-footer-obsessive__payment-item">
                {{ type | payment_type_svg_tag }}
              </span>
            {% endfor %}
          {% endif %}
        </div>

        <div class="os-footer-obsessive__selectors">
          {% if section.settings.show_language_selector and localization.available_languages.size > 1 %}
            <div class="os-footer-obsessive__selector os-footer-obsessive__selector--language">
              {% form 'localization', class: 'localization-form' %}
                <div class="os-footer-obsessive__selector-wrap">
                  <label class="visually-hidden" for="FooterLanguage-{{ section.id }}">Idioma</label>
                  <select
                    id="FooterLanguage-{{ section.id }}"
                    name="locale_code"
                    class="os-footer-obsessive__select"
                    onchange="this.form.submit()"
                  >
                    {% for language in localization.available_languages %}
                      <option
                        value="{{ language.iso_code }}"
                        {% if language.iso_code == localization.language.iso_code %}
                          selected
                        {% endif %}
                      >
                        {{ language.endonym_name | capitalize }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endform %}
            </div>
          {% endif %}

          {% if section.settings.show_country_selector and localization.available_countries.size > 1 %}
            <div class="os-footer-obsessive__selector os-footer-obsessive__selector--country">
              {% form 'localization', class: 'localization-form' %}
                <div class="os-footer-obsessive__selector-wrap os-footer-obsessive__selector-wrap--country">
                  <span class="os-footer-obsessive__selector-icon" aria-hidden="true">
                    <img
                      src="{{ 'earth-globe.webp' | asset_url }}"
                      alt=""
                      loading="lazy"
                      width="20"
                      height="20"
                    >
                  </span>

                  <label class="visually-hidden" for="FooterCountry-{{ section.id }}">País</label>
                  <select
                    id="FooterCountry-{{ section.id }}"
                    name="country_code"
                    class="os-footer-obsessive__select os-footer-obsessive__select--country"
                    onchange="this.form.submit()"
                  >
                    {% for country in localization.available_countries %}
                      <option
                        value="{{ country.iso_code }}"
                        {% if country.iso_code == localization.country.iso_code %}
                          selected
                        {% endif %}
                      >
                        {{ country.currency.iso_code }} $ | {{ country.name }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endform %}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="os-footer-obsessive__bottom-meta">
        {% if section.settings.copyright_text != blank %}
          <div class="os-footer-obsessive__copyright">
            {{ section.settings.copyright_text }}
          </div>
        {% else %}
          <div class="os-footer-obsessive__copyright">
            © {{ 'now' | date: '%Y' }}, {{ shop.name }}. {{ section.settings.rights_text }}
          </div>
        {% endif %}

        {% if section.settings.address_text != blank %}
          <div class="os-footer-obsessive__address">
            {{ section.settings.address_text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <style>
         @font-face {
                     font-family: 'Pulp';
                     src: url('{{ 'Pulp.woff2' | asset_url }}') format('woff2');
                     font-weight:500;
                     font-style: normal;
                    font-display: swap;
             }
        #{{ section_id }}{
          --bg: {{ section.settings.section_bg }};
          --text: {{ section.settings.text_color }};
          --muted: {{ section.settings.muted_color }};
          --newsletter-bg: {{ section.settings.newsletter_bg }};
          --newsletter-text: {{ section.settings.newsletter_text_color }};
          --input-bg: {{ section.settings.input_bg }};
          --input-text: {{ section.settings.input_text }};
          --input-placeholder: {{ section.settings.input_placeholder_color }};
          --bottom-bg: {{ section.settings.bottom_bg }};
          --top-space: {{ section.settings.top_spacing }}px;
          --bottom-space: {{ section.settings.bottom_spacing }}px;
          --radius: {{ section.settings.newsletter_radius }}px;
          --newsletter-pad-y: {{ section.settings.newsletter_padding_y }}px;
          --newsletter-pad-x: {{ section.settings.newsletter_padding_x }}px;
          --newsletter-title-size: {{ section.settings.newsletter_title_size }}px;
          --newsletter-title-size-mobile: {{ section.settings.newsletter_title_size_mobile }}px;
          --newsletter-text-size: {{ section.settings.newsletter_text_size }}px;
          --menu-title-size: {{ section.settings.menu_title_size }}px;
          --menu-link-size: {{ section.settings.menu_link_size }}px;
          --small-size: {{ section.settings.small_text_size }}px;
          background: var(--bg);
          color: var(--text);
          margin-top: 0;
        }

        #{{ section_id }} .page-width{
          max-width: {{ section.settings.page_width }}px;
        }

        #{{ section_id }}{
          padding-top: var(--top-space);
        }

        #{{ section_id }} .os-footer-obsessive__topline{
          display: flex;
          align-items: center;
          gap: 16px;
          flex-wrap: wrap;
          margin-bottom: 54px;
          padding: 0 14px;
        }

        #{{ section_id }} .os-footer-obsessive__topline-label{
          font-size: 21px;
          line-height: 1.2;
          font-weight: 500;
          color: var(--text);
          font-family: 'Pulp', Helvetica;
        }

        #{{ section_id }} .os-footer-obsessive__topline-handle{
          font-size: 21px;
          line-height: 1.2;
          font-weight: 500;
          color: var(--muted);
          text-decoration: none;
          transition: opacity .2s ease;
          font-family: 'Pulp', Helvetica;
        }

        #{{ section_id }} .os-footer-obsessive__topline-handle:hover{
          opacity: .75;
        }

        #{{ section_id }} .os-footer-obsessive__newsletter{
          background: var(--newsletter-bg);
          color: var(--newsletter-text);
          border-radius: var(--radius);
          padding: var(--newsletter-pad-y) var(--newsletter-pad-x);
          margin-bottom: 50px;
        }

        #{{ section_id }} .os-footer-obsessive__newsletter-grid{
          display: grid;
          grid-template-columns: minmax(301px, 1.2fr) minmax(383px, 1fr) minmax(23px, .9fr);
          gap: 41px;
          align-items: center;
        }

        #{{ section_id }} .os-footer-obsessive__newsletter-heading{
          margin: 0;
          color: var(--newsletter-text);
          font-size: var(--newsletter-title-size);
          line-height: 1.12;
          letter-spacing: -0.03em;
          font-weight: 500;
          max-width: 19ch;
          font-family: 'Pulp', Helvetica;
        }

        #{{ section_id }} .os-footer-obsessive__newsletter-text{
          font-size: var(--newsletter-text-size);
          line-height: 1.45;
          color: var(--newsletter-text);
          font-weight: 600;
          max-width: 57ch;
          font-family: Helvetica;
          letter-spacing: normal;
        }
                #{{ section_id }} .os-footer-obsessive__accordion-toggle{
                width: 100%;
                border: 0;
                background: transparent;
                padding: 0;
                margin: 0;
                display: block;
                text-align: left;
                cursor: default;
         }

            #{{ section_id }} .os-footer-obsessive__accordion-title{
            margin: 0;
            font-size: var(--menu-title-size);
            line-height: 1.2;
            color: var(--text);
            font-weight: 600;
            font-family: Helvetica;
            letter-spacing: normal;
            }

            #{{ section_id }} .os-footer-obsessive__accordion-icon{
            position: relative;
            width: 18px;
            height: 18px;
            flex: 0 0 18px;
            }

            #{{ section_id }} .os-footer-obsessive__accordion-icon::before,
            #{{ section_id }} .os-footer-obsessive__accordion-icon::after{
            content: '';
            position: absolute;
            left: 50%;
            top: 50%;
            background: #111;
            transform: translate(-50%, -50%);
            transition: opacity .2s ease;
            }

            #{{ section_id }} .os-footer-obsessive__accordion-icon::before{
            width: 12px;
            height: 1.5px;
            }

            #{{ section_id }} .os-footer-obsessive__accordion-icon::after{
            width: 1.5px;
            height: 12px;
            }

            #{{ section_id }} .os-footer-obsessive__accordion-toggle[aria-expanded="true"] .os-footer-obsessive__accordion-icon::after{
            opacity: 0;
            }

           #{{ section_id }} .os-footer-obsessive__accordion-content{
            padding-top: 0;
            max-height: none;
            opacity: 1;
            overflow: visible;
            transform: translateY(0);
            }

        #{{ section_id }} .os-footer-obsessive__newsletter-text p{
          margin: 0;
        }
        #{{ section_id }} .os-footer-obsessive__accordion-icon{
            display: none;
        }

        #{{ section_id }} .os-footer-obsessive__form{
          width: 100%;
        }

        #{{ section_id }} .os-footer-obsessive__form-inner{
          position: relative;
          width: 100%;
        }

        #{{ section_id }} .os-footer-obsessive__input{
          width: 100%;
          min-height: 49px;
          border: none;
          outline: none;
          box-shadow: none;
          background: var(--input-bg);
          color: var(--input-text);
          padding: 14px 62px 14px 22px;
          border-radius: 4px;
          font-size: 14px;
          line-height: 1.2;
          font-family: Helvetica;
        }
         #{{ section_id }} .os-footer-obsessive__form-message--success{
            color: #d7d7d7;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            }

            #{{ section_id }} .os-footer-obsessive__form-success-icon{
            width: 16px;
            height: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 16px;
            }

            #{{ section_id }} .os-footer-obsessive__form-success-icon svg{
            width: 16px;
            height: auto;
            display: block;
         }

        #{{ section_id }} .os-footer-obsessive__input::placeholder{
          color: var(--input-placeholder);
          opacity: 1;
        }

        #{{ section_id }} .os-footer-obsessive__submit{
          position: absolute;
          top: 50%;
          right: 14px;
          transform: translateY(-50%);
          width: 34px;
          height: 34px;
          border: none;
          background: transparent;
          color: #8e8e95;
          cursor: pointer;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          transition: transform .2s ease, opacity .2s ease;
        }

        #{{ section_id }} .os-footer-obsessive__submit:hover{
          transform: translateY(-50%) translateX(2px);
          opacity: .85;
        }

        #{{ section_id }} .os-footer-obsessive__submit svg{
          width: 22px;
          height: 22px;
          display: block;
        }

        #{{ section_id }} .os-footer-obsessive__form-message{
          margin-top: 12px;
          font-size: 13px;
          line-height: 1.35;
        }

        #{{ section_id }} .os-footer-obsessive__form-message--success{
          color: #d7d7d7;
        }

        #{{ section_id }} .os-footer-obsessive__form-message--error{
          color: #ffb9b9;
        }

        #{{ section_id }} .os-footer-obsessive__links{
          display: grid;
          grid-template-columns: repeat(4, minmax(80px, 1fr));
          gap: 32px 60px;
          padding-bottom: 58px;
        }

        #{{ section_id }} .os-footer-obsessive__menu-title{
          margin: 0 0 14px;
          font-size: var(--menu-title-size);
          line-height: 1.2;
          color: var(--text);
          font-weight: 600;
          font-family: Helvetica;
          letter-spacing: normal;
        }

        #{{ section_id }} .os-footer-obsessive__menu-list,
        #{{ section_id }} .os-footer-obsessive__social-list{
          list-style: none;
          margin: 0;
          padding: 0;
        }

        #{{ section_id }} .os-footer-obsessive__menu-item + .os-footer-obsessive__menu-item{
          /* margin-top: 10px; */
        }

        #{{ section_id }} .os-footer-obsessive__menu-link{
            text-decoration: none;
            color: var(--muted);
            font-size: var(--menu-link-size);
            line-height: 1.4;
            font-weight: 100;
            letter-spacing: normal;
            font-family: 'Circular';
            transition: opacity .2s ease;
            }

        #{{ section_id }} .os-footer-obsessive__menu-link:hover{
          opacity: .75;
        }

        #{{ section_id }} .os-footer-obsessive__social-list li + li{
          margin-top: 12px;
        }

        #{{ section_id }} .os-footer-obsessive__social-link{
          display: inline-flex;
          align-items: center;
          gap: 12px;
          text-decoration: none;
          color: var(--muted);
          font-size: var(--menu-link-size);
          line-height: 1.4;
          transition: opacity .2s ease;
        }

        #{{ section_id }} .os-footer-obsessive__social-link:hover{
          opacity: .75;
        }

        #{{ section_id }} .os-footer-obsessive__social-icon{
          width: 22px;
          height: 22px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          color: #66666c;
          flex: 0 0 22px;
        }

        #{{ section_id }} .os-footer-obsessive__social-icon svg{
          width: 22px;
          height: 22px;
          display: block;
        }

        #{{ section_id }} .os-footer-obsessive__bottom{
          background: var(--bottom-bg);
          padding: 18px 0 var(--bottom-space);
        }

        #{{ section_id }} .os-footer-obsessive__bottom-top{
          display: grid;
          grid-template-columns: 1fr auto;
          gap: 30px;
