  <script>
    (function () {
      const section = document.getElementById('{{ section_id }}');
      if (!section) return;

      const isMobile = () => window.innerWidth <= 749;
      const buttons = section.querySelectorAll('.os-footer-obsessive__accordion-toggle');

      function setOpen(button, open) {
        const contentId = button.getAttribute('aria-controls');
        const content = contentId ? section.querySelector('#' + CSS.escape(contentId)) : null;
        if (!content) return;

        button.setAttribute('aria-expanded', open ? 'true' : 'false');

        if (!isMobile()) {
          content.style.maxHeight = 'none';
          content.style.opacity = '1';
          content.style.transform = 'translateY(0)';
          content.style.paddingTop = '18px';
          content.style.overflow = 'visible';
          return;
        }

        if (open) {
          content.style.paddingTop = '18px';
          content.style.opacity = '1';
          content.style.transform = 'translateY(0)';
          content.style.overflow = 'hidden';
          content.style.maxHeight = content.scrollHeight + 24 + 'px';
        } else {
          content.style.maxHeight = content.scrollHeight + 'px';
          requestAnimationFrame(() => {
            content.style.maxHeight = '0px';
            content.style.opacity = '0';
            content.style.transform = 'translateY(-4px)';
            content.style.paddingTop = '0px';
            content.style.overflow = 'hidden';
          });
        }
      }

      function desktopReset() {
        buttons.forEach((button) => setOpen(button, true));
      }

      function mobileReset() {
        buttons.forEach((button) => {
          setOpen(button, false);
        });
      }

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          if (!isMobile()) return;

          const expanded = button.getAttribute('aria-expanded') === 'true';
          setOpen(button, !expanded);
        });
      });

      function handleResize() {
        if (isMobile()) {
          mobileReset();
        } else {
          desktopReset();
        }
      }

      handleResize();
      window.addEventListener('resize', handleResize);
    })();
  </script>

