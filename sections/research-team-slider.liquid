<section class="research-team research-team--{{ section.id }}">
  <div class="research-team__wrap">
    <div class="research-team__grid swiper-disabled">
      {% for block in section.blocks %}
        <article class="research-team__card" {{ block.shopify_attributes }}>
          <div class="research-team__image-wrap">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  class: 'research-team__image',
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 33vw, 78vw',
                  widths: '375, 550, 750, 900, 1100, 1200',
                  alt: block.settings.name
                | escape
              }}
            {% else %}
              <div class="research-team__image-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
          </div>

          <div class="research-team__content">
            {% if block.settings.name != blank %}
              <h3 class="research-team__name">{{ block.settings.name }}</h3>
            {% endif %}

            {% if block.settings.role != blank %}
              <div class="research-team__role">{{ block.settings.role }}</div>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="research-team__text rte">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>

  <style>
    .research-team--{{ section.id }} {
      background: {{ section.settings.section_bg }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .research-team--{{ section.id }} .research-team__wrap {
      max-width: {{ section.settings.container_width }}px;
      margin: 0 auto;
      padding-left: {{ section.settings.side_padding }}px;
      padding-right: {{ section.settings.side_padding }}px;
      box-sizing: border-box;
    }

    .research-team--{{ section.id }} .research-team__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: {{ section.settings.desktop_gap }}px;
    align-items: stretch;
    }

    .research-team--{{ section.id }} .research-team__card {
    background: {{ section.settings.card_bg }};
    overflow: hidden;
    min-width: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    }

    .research-team--{{ section.id }} .research-team__content {
    padding: {{ section.settings.content_padding_top }}px {{ section.settings.content_padding_side }}px {{ section.settings.content_padding_bottom }}px;
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    }

    .research-team--{{ section.id }} .research-team__image-wrap {
      position: relative;
      width: 100%;
      overflow: hidden;
      background: {{ section.settings.image_bg }};
      border-radius: {{ section.settings.image_radius }}px 0 0 0;
    }

    .research-team--{{ section.id }} .research-team__image,
    .research-team--{{ section.id }} .research-team__image-placeholder {
      display: block;
      width: 100%;
      height: {{ section.settings.image_height_desktop }}px;
      object-fit: {{ section.settings.image_fit_desktop }};
      object-position: center;
    }

    .research-team--{{ section.id }} .research-team__image-placeholder .placeholder-svg {
      width: 100%;
      height: 100%;
      display: block;
      background: #ececec;
      fill: #cfcfcf;
    }

    .research-team--{{ section.id }} .research-team__content {
      padding: {{ section.settings.content_padding_top }}px {{ section.settings.content_padding_side }}px {{ section.settings.content_padding_bottom }}px;
    }

    .research-team--{{ section.id }} .research-team__name {
      margin: 0 0 6px;
      color: {{ section.settings.name_color }};
      font-size: {{ section.settings.name_size }}px;
      line-height: 1.15;
      font-weight: {{ section.settings.name_weight }};
      letter-spacing: 0.63px;
    font-family: 'Pulp';
    }

    .research-team--{{ section.id }} .research-team__role {
      margin: 0 0 14px;
      color: {{ section.settings.role_color }};
      font-size: {{ section.settings.role_size }}px;
      line-height: 1.35;
      font-weight: {{ section.settings.role_weight }};
        font-family: 'Circular';
        letter-spacing: 0.63px;
    }

    .research-team--{{ section.id }} .research-team__text {
      color: {{ section.settings.text_color }};
      font-size: {{ section.settings.text_size }}px;
      line-height: {{ section.settings.text_line_height }};
      font-weight: {{ section.settings.text_weight }};
        font-family: 'Circular';
       letter-spacing: 0.63px;
    }

    .research-team--{{ section.id }} .research-team__text p {
      margin: 0;
    }

    @media screen and (max-width: 989px) {
      .research-team--{{ section.id }} {
        overflow: hidden;
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      }

      .research-team--{{ section.id }} .research-team__wrap {
        max-width: 100%;
        padding-left: {{ section.settings.side_padding_mobile }}px;
        padding-right: 0;
      }

      .research-team--{{ section.id }} .research-team__grid {
        display: flex;
        gap: {{ section.settings.mobile_gap }}px;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 10px;
        scrollbar-width: thin;
        }

        .research-team--{{ section.id }} .research-team__grid::-webkit-scrollbar {
        height: 4px;
        }

        .research-team--{{ section.id }} .research-team__grid::-webkit-scrollbar-track {
        background: transparent;
        }

        .research-team--{{ section.id }} .research-team__grid::-webkit-scrollbar-thumb {
        background: #bdbdbd;
        border-radius: 999px;
        }

      .research-team--{{ section.id }} .research-team__card {
        flex: 0 0 {{ section.settings.mobile_card_width }}%;
        scroll-snap-align: start;
        display: flex;
        flex-direction: column;
        height: auto;
        }
      .research-team--{{ section.id }} .research-team__image,
      .research-team--{{ section.id }} .research-team__image-placeholder {
        height: {{ section.settings.image_height_mobile }}px;
        object-fit: {{ section.settings.image_fit_mobile }};
      }

      .research-team--{{ section.id }} .research-team__content {
        padding: {{ section.settings.content_padding_top_mobile }}px {{ section.settings.content_padding_side_mobile }}px {{ section.settings.content_padding_bottom_mobile }}px;
      }

      .research-team--{{ section.id }} .research-team__name {
        font-size: {{ section.settings.name_size_mobile }}px;
      }

      .research-team--{{ section.id }} .research-team__role {
        font-size: {{ section.settings.role_size_mobile }}px;
        margin-bottom: 12px;
      }

      .research-team--{{ section.id }} .research-team__text {
        font-size: {{ section.settings.text_size_mobile }}px;
        line-height: {{ section.settings.text_line_height_mobile }};
      }
    }
  </style>
</section>

