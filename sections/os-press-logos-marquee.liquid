{% liquid
  assign section_id = 'os-press-logos-' | append: section.id
  assign has_blocks = false
  if section.blocks.size > 0
    assign has_blocks = true
  endif
%}

<section id="{{ section_id }}" class="os-press-logos">
  <div class="os-press-logos__inner{% unless section.settings.full_width %} page-width{% endunless %}{% if section.settings.full_width %} os-press-logos__inner--full{% endif %}">
    {% if section.settings.heading != blank %}
      <div class="os-press-logos__header">
        <h2 class="os-press-logos__heading">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    {% if has_blocks %}
      <div class="os-press-logos__viewport" data-step-slider>
        <div class="os-press-logos__marquee{% if section.settings.pause_on_hover %} os-press-logos__marquee--pause-hover{% endif %}">
          <div class="os-press-logos__track" data-track>
            {% for repeat in (1..2) %}
              {% for block in section.blocks %}
                {% liquid
                  assign logo = block.settings.logo
                  assign hover_logo = block.settings.hover_logo
                  assign logo_link = block.settings.link
                  assign alt_text = block.settings.alt | default: shop.name
                %}

                <div
                  class="os-press-logos__item"
                  {{ block.shopify_attributes }}
                  style="
                    --logo-width-desktop: {{ block.settings.logo_width_desktop }}px;
                    --logo-width-mobile: {{ block.settings.logo_width_mobile }}px;
                  "
                >
                  {% if logo_link != blank %}
                    <a href="{{ logo_link }}" class="os-press-logos__logo-link" aria-label="{{ alt_text | escape }}">
                  {% else %}
                    <div class="os-press-logos__logo-link" aria-label="{{ alt_text | escape }}">
                  {% endif %}

                  <div class="os-press-logos__logo-wrap">
                    {% if logo != blank %}
                      {{
                        logo
                        | image_url: width: 800
                        | image_tag:
                          class: 'os-press-logos__logo os-press-logos__logo--default',
                          loading: 'lazy',
                          widths: '160, 240, 320, 480, 640, 800',
                          alt: alt_text
                      }}
                    {% else %}
                      <div class="os-press-logos__placeholder os-press-logos__logo os-press-logos__logo--default">
                        {{ block.settings.alt | default: 'LOGO' }}
                      </div>
                    {% endif %}

                    {% if hover_logo != blank %}
                      {{
                        hover_logo
                        | image_url: width: 800
                        | image_tag:
                          class: 'os-press-logos__logo os-press-logos__logo--hover',
                          loading: 'lazy',
                          widths: '160, 240, 320, 480, 640, 800',
                          alt: alt_text
                      }}
                    {% endif %}
                  </div>

                  {% if logo_link != blank %}
                    </a>
                  {% else %}
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}
  </div>

  <style>
            #{{ section_id }} {
                --section-bg: {{ section.settings.background_color }};
                --section-text: {{ section.settings.text_color }};
                --section-padding-top: {{ section.settings.padding_top }}px;
                --section-padding-bottom: {{ section.settings.padding_bottom }}px;
                --logo-gap: {{ section.settings.logo_gap }}px;
                --logo-height-desktop: {{ section.settings.logo_height_desktop }}px;
                --logo-height-mobile: {{ section.settings.logo_height_mobile }}px;
                --marquee-duration: {{ section.settings.scroll_duration }}s;
                --step-pause: {{ section.settings.pause_time }}ms;
                --logo-opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
                --logo-hover-lift: {{ section.settings.hover_lift }}px;
                --logo-radius: {{ section.settings.logo_radius }}px;
                --default-filter: grayscale({{ section.settings.default_grayscale }}%) opacity({{ section.settings.logo_opacity }}%);
                --hover-filter: grayscale(0%) opacity(100%);
            }

            #{{ section_id }}.os-press-logos {
              background: var(--section-bg);
              color: var(--section-text);
              padding-top: var(--section-padding-top);
              padding-bottom: var(--section-padding-bottom);
              overflow: hidden;
            }

            #{{ section_id }} .os-press-logos__inner {
              position: relative;
            }

            #{{ section_id }} .os-press-logos__inner--full {
              max-width: 100%;
              padding-left: 0;
              padding-right: 0;
            }

            #{{ section_id }} .os-press-logos__header {
              text-align: center;
              margin-bottom: 22px;
            }

            #{{ section_id }} .os-press-logos__heading {
              margin: 0;
              color: var(--section-text);
            }

            #{{ section_id }} .os-press-logos__viewport {
              position: relative;
              overflow: hidden;
              width: 100%;
            }

            #{{ section_id }} .os-press-logos__marquee {
              width: max-content;
              min-width: 100%;
              display: flex;
              align-items: center;
            }

            #{{ section_id }} .os-press-logos__track {
                display: flex;
                align-items: center;
                gap: var(--logo-gap);
                width: max-content;
                will-change: transform;
            }

            #{{ section_id }} .os-press-logos__track.is-marquee-mobile {
                animation: osPressLogosMarquee-{{ section.id }} var(--marquee-duration) linear infinite;
            }

            #{{ section_id }} .os-press-logos__marquee--pause-hover:hover .os-press-logos__track.is-marquee-mobile {
             animation-play-state: paused;
            }

            #{{ section_id }} .os-press-logos__track.is-step-mode {
             animation: none;
            }

            #{{ section_id }} .os-press-logos__marquee--pause-hover:hover .os-press-logos__track {
              animation-play-state: paused;
            }

            #{{ section_id }} .os-press-logos__item {
              flex: 0 0 auto;
              display: flex;
              align-items: center;
              justify-content: center;
            }

            #{{ section_id }} .os-press-logos__logo-link {
              display: inline-flex;
              align-items: center;
              justify-content: center;
              text-decoration: none;
              color: inherit;
              position: relative;
            }
            @media screen and (max-width: 749px) {
                #{{ section_id }} .os-press-logos__inner,
                #{{ section_id }} .os-press-logos__viewport,
                #{{ section_id }} .os-press-logos__marquee {
                    width: 100%;
                    max-width: 100%;
                }

                #{{ section_id }}.os-press-logos {
                    padding-left: 0;
                    padding-right: 0;
            }
            }

            #{{ section_id }} .os-press-logos__logo-wrap {
              position: relative;
              width: var(--logo-width-desktop);
              max-width: 100%;
              height: var(--logo-height-desktop);
              display: flex;
              align-items: center;
              justify-content: center;
              border-radius: var(--logo-radius);
              transition: transform 0.28s ease, opacity 0.28s ease;
              transform: translateY(0);
            }

            #{{ section_id }} .os-press-logos__logo {
              max-width: 100%;
              width: 100%;
              height: 100%;
              object-fit: contain;
              display: block;
              transition:
                opacity 0.28s ease,
                transform 0.28s ease,
                filter 0.28s ease;
              backface-visibility: hidden;
              -webkit-backface-visibility: hidden;
            }

            #{{ section_id }} .os-press-logos__logo--default {
              opacity: 1;
              filter: var(--default-filter);
            }

            #{{ section_id }} .os-press-logos__logo--hover {
              position: absolute;
              inset: 0;
              opacity: 0;
              filter: var(--hover-filter);
              pointer-events: none;
            }

            #{{ section_id }} .os-press-logos__logo-link:hover .os-press-logos__logo-wrap {
              transform: translateY(calc(var(--logo-hover-lift) * -1));
            }

            #{{ section_id }} .os-press-logos__logo-link:hover .os-press-logos__logo--default {
              {% if section.settings.use_filter_fallback %}
                filter: var(--hover-filter);
              {% endif %}
              opacity: {% if section.settings.keep_default_on_hover %}1{% else %}0{% endif %};
            }

            #{{ section_id }} .os-press-logos__logo-link:hover .os-press-logos__logo--hover {
              opacity: 1;
            }

            #{{ section_id }} .os-press-logos__placeholder {
              min-width: 140px;
              padding: 10px 18px;
              font-size: 18px;
              line-height: 1;
              white-space: nowrap;
              color: rgba(0,0,0,.55);
              text-transform: uppercase;
              letter-spacing: .08em;
            }

            @keyframes osPressLogosMarquee-{{ section.id }} {
              0% {
                transform: translate3d(0, 0, 0);
              }
              100% {
                transform: translate3d(-50%, 0, 0);
              }
            }

            @media screen and (max-width: 749px) {
      #{{ section_id }} .os-press-logos__track {
        gap: calc(var(--logo-gap) * 0.45);
      }

              #{{ section_id }} .os-press-logos__logo-wrap {
                width: var(--logo-width-mobile);
                height: var(--logo-height-mobile);
              }
            }
            #{{ section_id }} .os-press-logos__viewport {
          cursor: grab;
          user-select: none;
        }

        #{{ section_id }} .os-press-logos__viewport.is-dragging {
          cursor: grabbing;
        }

        #{{ section_id }} .os-press-logos__viewport.is-dragging * {
          user-select: none;
          pointer-events: none;
        }
        @media screen and (max-width: 749px) {
      #{{ section_id }}.os-press-logos {
        width: 100%;
        max-width: 100%;
        overflow: hidden;
        padding-left: 0 !important;
        padding-right: 0 !important;
      }

      #{{ section_id }} .os-press-logos__inner,
      #{{ section_id }} .os-press-logos__inner--full {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding-left: 0 !important;
        padding-right: 0 !important;
      }

      #{{ section_id }} .os-press-logos__viewport {
        width: 100vw;
        max-width: 100vw;
        overflow: hidden;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
      }

      #{{ section_id }} .os-press-logos__marquee {
        width: max-content;
        min-width: 100%;
      }

      #{{ section_id }} .os-press-logos__track {
        gap: calc(var(--logo-gap) * 0.45);
      }

      #{{ section_id }} .os-press-logos__item {
        flex: 0 0 auto;
      }

      #{{ section_id }} .os-press-logos__logo-wrap {
        width: var(--logo-width-mobile);
        height: var(--logo-height-mobile);
      }
    }
  </style>
</section>

<script>
  (() => {
    const section = document.getElementById('{{ section_id }}');
    if (!section) return;

    const viewport = section.querySelector('[data-step-slider]');
    const track = section.querySelector('[data-track]');
    if (!viewport || !track) return;

    const desktopBreakpoint = 990;
    const pauseTime = {{ section.settings.pause_time | json }};
    const slideDuration = {{ section.settings.slide_duration | json }};
    const pauseOnHover = {{ section.settings.pause_on_hover | json }};

    let autoplayTimer = null;
    let isHovered = false;
    let isDragging = false;
    let startX = 0;
    let startOffset = 0;
    let currentOffset = 0;
    let stepWidth = 0;
    let originalWidth = 0;
    let resizeTimer = null;

    function getAllItems() {
      return Array.from(track.querySelectorAll('.os-press-logos__item'));
    }

    function getOriginalItems() {
      const items = getAllItems();
      return items.slice(0, items.length / 2);
    }

    function measure() {
      const originalItems = getOriginalItems();
      if (!originalItems.length) return;

      const first = originalItems[0];
      const second = originalItems[1];
      const firstRect = first.getBoundingClientRect();

      if (second) {
        const secondRect = second.getBoundingClientRect();
        stepWidth = secondRect.left - firstRect.left;
      } else {
        const styles = window.getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap || 0);
        stepWidth = firstRect.width + gap;
      }

      originalWidth = 0;
      originalItems.forEach((item, index) => {
        const rect = item.getBoundingClientRect();
        originalWidth += rect.width;

        if (index < originalItems.length - 1) {
          const styles = window.getComputedStyle(track);
          const gap = parseFloat(styles.columnGap || styles.gap || 0);
          originalWidth += gap;
        }
      });
    }

    function normalizeOffset(value) {
      if (!originalWidth) return 0;
      let normalized = value % originalWidth;
      if (normalized < 0) normalized += originalWidth;
      return normalized;
    }

    function applyTransform(animated = true) {
      if (animated) {
        track.style.transition = `transform ${slideDuration}ms ease`;
      } else {
        track.style.transition = 'none';
      }

      track.style.transform = `translate3d(-${currentOffset}px, 0, 0)`;
    }

    function clearAutoplay() {
      if (autoplayTimer) clearTimeout(autoplayTimer);
      autoplayTimer = null;
    }

    function scheduleNext() {
      clearAutoplay();

      if (window.innerWidth < desktopBreakpoint) return;
      if (pauseOnHover && isHovered) return;
      if (isDragging) return;
      if (!stepWidth || !originalWidth) return;

      autoplayTimer = setTimeout(() => {
        advanceStep();
      }, pauseTime);
    }

    function resetSeamlesslyIfNeeded() {
      if (!originalWidth) return;

      if (currentOffset >= originalWidth) {
        currentOffset = normalizeOffset(currentOffset);

        requestAnimationFrame(() => {
          track.style.transition = 'none';
          track.style.transform = `translate3d(-${currentOffset}px, 0, 0)`;
        });
      }
    }

    function advanceStep() {
      if (window.innerWidth < desktopBreakpoint) return;
      if (isDragging) return;

      currentOffset += stepWidth;
      applyTransform(true);

      window.setTimeout(() => {
        resetSeamlesslyIfNeeded();
        scheduleNext();
      }, slideDuration + 30);
    }

    function enableDesktopMode() {
      measure();
      currentOffset = normalizeOffset(currentOffset);
      track.classList.remove('is-marquee-mobile');
      track.classList.add('is-step-mode');
      applyTransform(false);
      scheduleNext();
    }

    function enableMobileMode() {
      clearAutoplay();
      track.classList.remove('is-step-mode');
      track.classList.add('is-marquee-mobile');
      track.style.transition = '';
      track.style.transform = '';
    }

    function setupMode() {
      measure();

      if (window.innerWidth >= desktopBreakpoint) {
        enableDesktopMode();
      } else {
        enableMobileMode();
      }
    }

    function onPointerDown(event) {
      if (window.innerWidth < desktopBreakpoint) return;
      if (event.button !== 0) return;

      isDragging = true;
      startX = event.clientX;
      startOffset = currentOffset;

      clearAutoplay();
      viewport.classList.add('is-dragging');
      track.style.transition = 'none';
    }

    function onPointerMove(event) {
      if (!isDragging) return;

      const delta = event.clientX - startX;
      currentOffset = normalizeOffset(startOffset - delta);
      track.style.transform = `translate3d(-${currentOffset}px, 0, 0)`;
    }

    function onPointerUp() {
      if (!isDragging) return;

      isDragging = false;
      currentOffset = normalizeOffset(currentOffset);
      viewport.classList.remove('is-dragging');
      applyTransform(false);
      scheduleNext();
    }

    if (pauseOnHover) {
      section.addEventListener('mouseenter', () => {
        isHovered = true;
        clearAutoplay();
      });

      section.addEventListener('mouseleave', () => {
        isHovered = false;
        scheduleNext();
      });
    }

    viewport.addEventListener('mousedown', onPointerDown);
    window.addEventListener('mousemove', onPointerMove);
    window.addEventListener('mouseup', onPointerUp);
    window.addEventListener('mouseleave', onPointerUp);

    viewport.addEventListener('dragstart', (event) => {
      event.preventDefault();
    });

    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        setupMode();
      }, 180);
    });

    setupMode();
  })();
</script>

{% schema %}
{
  "name": "OS Press logos marquee",
  "tag": "section",
  "class": "section section-os-press-logos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Press Logos"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Ancho completo",
      "default": true
    },
    {
      "type": "range",
      "id": "scroll_duration",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Duración del desplazamiento",
      "default": 22
    },
    {
      "type": "range",
      "id": "pause_time",
      "min": 1000,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "label": "Pausa entre deslizamientos en escritorio",
      "default": 5000
    },
    {
      "type": "range",
      "id": "slide_duration",
      "min": 200,
      "max": 2000,
      "step": 100,
      "unit": "ms",
      "label": "Duración del deslizamiento en escritorio",
      "default": 700
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pausar animación al pasar el mouse",
      "default": false
    },
    {
      "type": "range",
      "id": "logo_gap",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Espacio entre logos",
      "default": 60
    },
    {
      "type": "range",
      "id": "logo_height_desktop",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Altura de logo escritorio",
      "default": 44
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "min": 16,
      "max": 90,
      "step": 2,
      "unit": "px",
      "label": "Altura de logo móvil",
      "default": 32
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacidad logo normal",
      "default": 45
    },
    {
      "type": "range",
      "id": "default_grayscale",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Escala de grises logo normal",
      "default": 100
    },
    {
      "type": "range",
      "id": "hover_lift",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Elevación al hover",
      "default": 4
    },
    {
      "type": "range",
      "id": "logo_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Radio del contenedor del logo",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "use_filter_fallback",
      "label": "Quitar filtros al hover si no subes logo hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "keep_default_on_hover",
      "label": "Mantener visible el logo normal al hover",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo normal"
        },
        {
          "type": "image_picker",
          "id": "hover_logo",
          "label": "Logo hover (color real)"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Texto alternativo",
          "default": "Press logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link del logo"
        },
        {
          "type": "range",
          "id": "logo_width_desktop",
          "min": 60,
          "max": 320,
          "step": 4,
          "unit": "px",
          "label": "Ancho escritorio",
          "default": 172
        },
        {
          "type": "range",
          "id": "logo_width_mobile",
          "min": 40,
          "max": 220,
          "step": 4,
          "unit": "px",
          "label": "Ancho móvil",
          "default": 120
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OS Press logos marquee",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        }
      ]
    }
  ]
}
{% endschema %}
