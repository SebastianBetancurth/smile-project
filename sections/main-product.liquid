<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}
  {%- if product.quantity_price_breaks_configured? -%}
    {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
    @media screen and (max-width: 749px) {
       .os-pdp-right__eyebrow,
        .os-pdp-right__panel--offer,
        .os-pdp-feature-icons,
        .os-pdp-description-tabs {
          width: var(--os-mobile-width, 100%);
          max-width: var(--os-mobile-width, 100%);
          margin: var(--os-mobile-margin, 0 auto);
        }
      }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- if product.quantity_price_breaks_configured? -%}
    <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
  <div class="page-width">
    <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}">
      <div class="grid__item product__media-wrapper">
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>

      <div class="os-pdp-mobile-after-media" data-mobile-after-media></div>
      <div class="product__info-wrapper grid__item{% if settings.page_width > 1400 and section.settings.media_size == "small" %} product__info-wrapper--extra-padding{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <section
          id="ProductInfo-{{ section.id }}"
          class="product__info-container os-pdp-info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
        >
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- assign price_block = section.blocks | where: 'type', 'price' | first -%}
          {%- assign variant_picker_block = section.blocks | where: 'type', 'variant_picker' | first -%}
          {%- assign quantity_block = section.blocks | where: 'type', 'quantity_selector' | first -%}
          {%- assign buy_buttons_block = section.blocks | where: 'type', 'buy_buttons' | first -%}
          {%- assign share_block = section.blocks | where: 'type', 'share' | first -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          {%- assign color_block = section.blocks | where: 'type', 'color_block' | first -%}

          <div
            class="os-pdp-right"
            {% if color_block %}
              style="
                --os-pdp-panel-bg: {{ color_block.settings.panel_bg }};
                --os-pdp-card-bg: {{ color_block.settings.card_bg }};
                --os-pdp-border-color: {{ color_block.settings.border_color }};
                --os-pdp-button-bg: {{ color_block.settings.button_bg }};
                --os-pdp-button-text: {{ color_block.settings.button_text }};
                --os-pdp-panel-radius: {{ color_block.settings.panel_radius }}px;
                --os-pdp-panel-padding: {{ color_block.settings.panel_padding }}px;
                --os-pdp-panel-gap: {{ color_block.settings.panel_gap }}px;
                --os-pdp-panel-max-width: {{ color_block.settings.panel_max_width }}px;
                --os-pdp-panel-padding-x: {{ color_block.settings.panel_padding_x }}px;
                --os-pdp-panel-padding-y: {{ color_block.settings.panel_padding_y }}px;
                --os-pdp-offer-box-padding: {{ color_block.settings.offer_box_padding }}px;
                --os-pdp-offer-box-radius: {{ color_block.settings.offer_box_radius }}px;
              "
            {% endif %}
          >
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'desc_tabs_block' %}
                  <div
                    class="os-pdp-description-tabs"
                    {{ block.shopify_attributes }}
                    style="
                      --os-dt-bg: {{ block.settings.block_bg }};
                      --os-dt-bg-mobile: {{ block.settings.block_bg_mobile }};
                      --os-dt-border: {{ block.settings.border_color }};
                      --os-dt-border-mobile: {{ block.settings.border_color_mobile }};
                      --os-dt-radius: {{ block.settings.border_radius }}px;
                      --os-dt-padding-x: {{ block.settings.padding_x }}px;
                      --os-dt-padding-y: {{ block.settings.padding_y }}px;
                      --os-dt-heading-color: {{ block.settings.heading_color }};
                      --os-dt-heading-color-mobile: {{ block.settings.heading_color_mobile }};
                      --os-dt-text-color: {{ block.settings.text_color }};
                      --os-dt-text-color-mobile: {{ block.settings.text_color_mobile }};
                      --os-dt-row-title-color: {{ block.settings.row_title_color }};
                      --os-dt-row-title-color-mobile: {{ block.settings.row_title_color_mobile }};
                      --os-dt-title-size: {{ block.settings.title_size }}px;
                      --os-dt-text-size: {{ block.settings.text_size }}px;
                      --os-dt-row-title-size: {{ block.settings.row_title_size }}px;
                      --os-dt-margin-top: {{ block.settings.block_margin_top }}px;
                      --os-dt-margin-bottom: {{ block.settings.block_margin_bottom }}px;
                      --os-mobile-width: {{ block.settings.mobile_width }}%;
                          {% case block.settings.mobile_align %}
                            {% when 'left' %}
                              --os-mobile-margin: 0 auto 0 0;
                            {% when 'right' %}
                              --os-mobile-margin: 0 0 0 auto;
                            {% else %}
                              --os-mobile-margin: 0 auto;
                          {% endcase %}
                    "
                  >
                    {% if product.description != blank %}
                      <div class="os-pdp-description-tabs__description rte">
                        {{ product.description }}
                      </div>
                    {% endif %}

                    <div class="os-pdp-description-tabs__rows">
                      {% if block.settings.tab_title_1 != blank %}
                        <details class="os-pdp-description-tabs__row">
                          <summary>
                            <span class="os-pdp-description-tabs__row-title">{{ block.settings.tab_title_1 }}</span>
                            <span class="os-pdp-description-tabs__icon"></span>
                          </summary>
                          <div class="os-pdp-description-tabs__content rte">
                            <div class="os-pdp-description-tabs__content-inner">
                              {{ block.settings.tab_content_1 }}
                            </div>
                          </div>
                        </details>
                      {% endif %}

                      {% if block.settings.tab_title_2 != blank %}
                        <details class="os-pdp-description-tabs__row">
                          <summary>
                            <span class="os-pdp-description-tabs__row-title">{{ block.settings.tab_title_2 }}</span>
                            <span class="os-pdp-description-tabs__icon"></span>
                          </summary>
                          <div class="os-pdp-description-tabs__content rte">
                            <div class="os-pdp-description-tabs__content-inner">
                              {{ block.settings.tab_content_2 }}
                            </div>
                          </div>
                        </details>
                      {% endif %}

                      {% if block.settings.tab_title_3 != blank %}
                        <details class="os-pdp-description-tabs__row">
                          <summary>
                            <span class="os-pdp-description-tabs__row-title">{{ block.settings.tab_title_3 }}</span>
                            <span class="os-pdp-description-tabs__icon"></span>
                          </summary>
                          <div class="os-pdp-description-tabs__content rte">
                            <div class="os-pdp-description-tabs__content-inner">
                              {{ block.settings.tab_content_3 }}
                            </div>
                          </div>
                        </details>
                      {% endif %}
                      {% if block.settings.tab_title_4 != blank %}
                        <details class="os-pdp-description-tabs__row">
                          <summary>
                            <span class="os-pdp-description-tabs__row-title">{{ block.settings.tab_title_4 }}</span>
                            <span class="os-pdp-description-tabs__icon"></span>
                          </summary>
                          <div class="os-pdp-description-tabs__content rte">
                            <div class="os-pdp-description-tabs__content-inner">
                              {{ block.settings.tab_content_4 }}
                            </div>
                          </div>
                        </details>
                      {% endif %}

                      {% if block.settings.tab_title_5 != blank %}
                        <details class="os-pdp-description-tabs__row">
                          <summary>
                            <span class="os-pdp-description-tabs__row-title">{{ block.settings.tab_title_5 }}</span>
                            <span class="os-pdp-description-tabs__icon"></span>
                          </summary>
                          <div class="os-pdp-description-tabs__content rte">
                            <div class="os-pdp-description-tabs__content-inner">
                              {{ block.settings.tab_content_6 }}
                            </div>
                          </div>
                        </details>
                      {% endif %}

                      {% if block.settings.tab_title_6 != blank %}
                        <details class="os-pdp-description-tabs__row">
                          <summary>
                            <span class="os-pdp-description-tabs__row-title">{{ block.settings.tab_title_6 }}</span>
                            <span class="os-pdp-description-tabs__icon"></span>
                          </summary>
                          <div class="os-pdp-description-tabs__content rte">
                            <div class="os-pdp-description-tabs__content-inner">
                              {{ block.settings.tab_content_6 }}
                            </div>
                          </div>
                        </details>
                      {% endif %}

                      {% if block.settings.tab_title_7 != blank %}
                        <details class="os-pdp-description-tabs__row">
                          <summary>
                            <span class="os-pdp-description-tabs__row-title">{{ block.settings.tab_title_7 }}</span>
                            <span class="os-pdp-description-tabs__icon"></span>
                          </summary>
                          <div class="os-pdp-description-tabs__content rte">
                            <div class="os-pdp-description-tabs__content-inner">
                              {{ block.settings.tab_content_7 }}
                            </div>
                          </div>
                        </details>
                      {% endif %}
                    </div>
                  </div>
                {% when 'eyebrow_block' %}
                  {% if block.settings.text != blank %}
                    <div
                      class="os-pdp-right__eyebrow"
                      {{ block.shopify_attributes }}
                      style="
                        --os-eyebrow-text-color: {{ block.settings.text_color }};
                        --os-eyebrow-text-color-mobile: {{ block.settings.text_color_mobile }};
                        --os-mobile-width: {{ block.settings.mobile_width }}%;
                        {% case block.settings.mobile_align %}
                          {% when 'left' %}
                            --os-mobile-margin: 0 auto 0 0;
                          {% when 'right' %}
                            --os-mobile-margin: 0 0 0 auto;
                          {% else %}
                            --os-mobile-margin: 0 auto;
                        {% endcase %}
                        color: var(--os-eyebrow-text-color);
                        letter-spacing: {{ block.settings.letter_spacing }}px;
                        margin-bottom: {{ block.settings.margin_bottom }}px;
                        {% if block.settings.uppercase %}text-transform: uppercase;{% endif %}
                      "
                    >
                      {{ block.settings.text }}
                    </div>
                  {% endif %}

                {% when 'title' %}
                  <h1 class="os-pdp-right__title" {{ block.shopify_attributes }}>
                    {{ product.title | escape }}
                  </h1>
                {% when 'feature_icons_block' %}
                  <div
                    class="os-pdp-feature-icons"
                    {{ block.shopify_attributes }}
                    style="
                      --os-fi-bg: {{ block.settings.block_bg }};
                      --os-fi-bg-mobile: {{ block.settings.block_bg_mobile }};
                      --os-fi-border: {{ block.settings.border_color }};
                      --os-fi-border-mobile: {{ block.settings.border_color_mobile }};
                      --os-fi-radius: {{ block.settings.border_radius }}px;
                      --os-fi-padding-x: {{ block.settings.padding_x }}px;
                      --os-fi-padding-y: {{ block.settings.padding_y }}px;
                      --os-fi-gap: {{ block.settings.item_gap }}px;
                      --os-fi-icon-size: {{ block.settings.icon_size }}px;
                      --os-fi-title-size: {{ block.settings.title_size }}px;
                      --os-fi-text-size: {{ block.settings.text_size }}px;
                      --os-fi-title-color: {{ block.settings.title_color }};
                      --os-fi-title-color-mobile: {{ block.settings.title_color_mobile }};
                      --os-fi-text-color: {{ block.settings.text_color }};
                      --os-fi-text-color-mobile: {{ block.settings.text_color_mobile }};
                      --os-fi-margin-top: {{ block.settings.block_margin_top }}px;
                      --os-fi-margin-bottom: {{ block.settings.block_margin_bottom }}px;
                      --os-mobile-width: {{ block.settings.mobile_width }}%;
                      {% case block.settings.mobile_align %}
                        {% when 'left' %}
                          --os-mobile-margin: 0 auto 0 0;
                        {% when 'right' %}
                          --os-mobile-margin: 0 0 0 auto;
                        {% else %}
                          --os-mobile-margin: 0 auto;
                      {% endcase %}
                    "
                  >
                    <div class="os-pdp-feature-icons__grid">
                      {% for i in (1..3) %}
                        {% liquid
                          assign icon_key = 'icon_' | append: i
                          assign title_key = 'title_' | append: i
                          assign text_key = 'text_' | append: i
                          assign top_key = 'space_top_' | append: i
                          assign bottom_key = 'space_bottom_' | append: i
                        %}
                        <div
                          class="os-pdp-feature-icons__item"
                          style="
                            --os-fi-item-top: {{ block.settings[top_key] }}px;
                            --os-fi-item-bottom: {{ block.settings[bottom_key] }}px;
                          "
                        >
                          {% if block.settings[icon_key] != blank %}
                            <div class="os-pdp-feature-icons__icon-wrap">
                              <img
                                src="{{ block.settings[icon_key] | image_url: width: 120 }}"
                                alt="{{ block.settings[title_key] | escape }}"
                                loading="lazy"
                                width="60"
                                height="60"
                                class="os-pdp-feature-icons__icon"
                              >
                            </div>
                          {% endif %}

                          {% if block.settings[title_key] != blank %}
                            <div class="os-pdp-feature-icons__title">
                              {{ block.settings[title_key] | newline_to_br }}
                            </div>
                          {% endif %}

                          {% if block.settings[text_key] != blank %}
                            <div class="os-pdp-feature-icons__text">
                              {{ block.settings[text_key] }}
                            </div>
                          {% endif %}
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                {% when 'purchase_offer_block' %}
                  <div
                    class="os-pdp-right__panel os-pdp-right__panel--offer"
                    {{ block.shopify_attributes }}
                    style="
                      --os-offer-panel-bg: {{ block.settings.offer_panel_bg }};
                      --os-offer-panel-bg-mobile: {{ block.settings.offer_panel_bg_mobile }};
                      --os-offer-card-bg: {{ block.settings.card_bg }};
                      --os-offer-card-bg-mobile: {{ block.settings.card_bg_mobile }};
                      --os-offer-card-active-bg: {{ block.settings.card_active_bg }};
                      --os-offer-card-active-bg-mobile: {{ block.settings.card_active_bg_mobile }};
                      --os-offer-card-border: {{ block.settings.card_border_color }};
                      --os-offer-card-border-mobile: {{ block.settings.card_border_color_mobile }};
                      --os-offer-card-active-border: {{ block.settings.card_active_border_color }};
                      --os-offer-card-active-border-mobile: {{ block.settings.card_active_border_color_mobile }};
                      --os-offer-heading-color: {{ block.settings.heading_color }};
                      --os-offer-heading-color-mobile: {{ block.settings.heading_color_mobile }};
                      --os-offer-price-color: {{ block.settings.price_color }};
                      --os-offer-price-color-mobile: {{ block.settings.price_color_mobile }};
                      --os-offer-compare-color: {{ block.settings.compare_color }};
                      --os-offer-compare-color-mobile: {{ block.settings.compare_color_mobile }};
                      --os-offer-badge-color: {{ block.settings.badge_color }};
                      --os-offer-badge-color-mobile: {{ block.settings.badge_color_mobile }};
                      --os-offer-label-color: {{ block.settings.label_color }};
                      --os-offer-label-color-mobile: {{ block.settings.label_color_mobile }};
                      --os-offer-text-color: {{ block.settings.text_color }};
                      --os-offer-text-color-mobile: {{ block.settings.text_color_mobile }};
                      --os-mobile-width: {{ block.settings.mobile_width }}%;
                        {% case block.settings.mobile_align %}
                          {% when 'left' %}
                            --os-mobile-margin: 0 auto 0 0;
                          {% when 'right' %}
                            --os-mobile-margin: 0 0 0 auto;
                          {% else %}
                            --os-mobile-margin: 0 auto;
                        {% endcase %}
                    "
                  >
                    {% if price_block %}
                      <div class="os-pdp-right__price-wrap" id="price-{{ section.id }}" role="status">
                        <span class="os-pdp-right__price-current" data-custom-price-current>
                          {{ current_variant.price | money }}
                        </span>

                        <span
                          class="os-pdp-right__price-compare{% unless current_variant.compare_at_price > current_variant.price %} is-hidden{% endunless %}"
                          data-custom-price-compare
                        >
                          {% if current_variant.compare_at_price > current_variant.price %}
                            {{ current_variant.compare_at_price | money }}
                          {% endif %}
                        </span>

                        {% assign save_percentage = 0 %}
                        {% if current_variant.compare_at_price > current_variant.price %}
                          {% assign save_percentage = current_variant.compare_at_price
                            | minus: current_variant.price
                            | times: 100.0
                            | divided_by: current_variant.compare_at_price
                            | round
                          %}
                        {% endif %}

                        <span
                          class="os-pdp-right__save-badge{% if save_percentage == 0 %} is-hidden{% endif %}"
                          data-custom-price-badge
                        >
                          {{ block.settings.badge_prefix }}
                          <span data-custom-price-badge-value>&nbsp{{ save_percentage }}%</span>
                        </span>
                      </div>
                    {% endif %}

                    <div class="os-pdp-right__purchase-box">
                      {% if block.settings.heading != blank %}
                        <h3 class="os-pdp-right__purchase-title">{{ block.settings.heading }}</h3>
                      {% endif %}

                      {% assign purchase_option = product.options_with_values.first %}
                      {% if purchase_option != blank %}
                        <div
                          class="os-pdp-right__purchase-options"
                          data-purchase-options
                          data-option-name="{{ purchase_option.name | escape }}"
                          data-option-position="1"
                        >
                          {% for value in purchase_option.values %}
                            {% assign matched_variant = null %}
                            {% for variant in product.variants %}
                              {% if variant.option1 == value %}
                                {% assign matched_variant = variant %}
                                {% break %}
                              {% endif %}
                            {% endfor %}

                            {% assign is_active = false %}
                            {% if current_variant.option1 == value %}
                              {% assign is_active = true %}
                            {% endif %}

                            <button
                              type="button"
                              class="os-pdp-purchase-card{% if is_active %} is-active{% else %} is-collapsed{% endif %}"
                              data-purchase-card
                              data-option-value="{{ value | escape }}"
                              data-variant-id="{{ matched_variant.id }}"
                              data-price="{{ matched_variant.price | money }}"
                              data-compare="{% if matched_variant.compare_at_price > matched_variant.price %}{{ matched_variant.compare_at_price | money }}{% endif %}"
                              aria-pressed="{% if is_active %}true{% else %}false{% endif %}"
                            >
                              <span class="os-pdp-purchase-card__radio"></span>

                              <span class="os-pdp-purchase-card__content">
                                <span class="os-pdp-purchase-card__top">
                                  <span class="os-pdp-purchase-card__label">
                                    {{ value }}
                                  </span>

                                  <span class="os-pdp-purchase-card__prices">
                                    <span class="os-pdp-purchase-card__price">
                                      {{ matched_variant.price | money }}
                                    </span>

                                    {% if matched_variant.compare_at_price > matched_variant.price %}
                                      <span class="os-pdp-purchase-card__compare">
                                        {{ matched_variant.compare_at_price | money }}
                                      </span>
                                    {% endif %}
                                  </span>
                                </span>

                                {% if forloop.first %}
                                  <span
                                    class="os-pdp-purchase-card__subtext"
                                    style="font-size: {{ block.settings.small_note_size }}px;"
                                  >
                                    {% if block.settings.option_one_line_1 != blank %}
                                      <span class="os-pdp-purchase-card__small-note">
                                        {{- block.settings.option_one_line_1 -}}
                                      </span>
                                    {% endif %}
                                  </span>

                                  {% if block.settings.details_heading != blank %}
                                    <div
                                      class="os-pdp-purchase-card__details-heading"
                                      style="font-size: {{ block.settings.details_text_size }}px;"
                                    >
                                      {{ block.settings.details_heading }}
                                    </div>
                                  {% endif %}

                                  <div
                                    class="os-pdp-purchase-card__benefits"
                                    style="font-size: {{ block.settings.benefit_text_size }}px;"
                                  >
                                    {% if block.settings.option_one_line_2 != blank %}
                                      <div class="os-pdp-purchase-card__benefit-row">
                                        {% if block.settings.benefit_icon_1 != blank %}
                                          <img
                                            src="{{ block.settings.benefit_icon_1 | image_url: width: 40 }}"
                                            alt=""
                                            loading="lazy"
                                            width="18"
                                            height="18"
                                            class="os-pdp-purchase-card__benefit-icon"
                                          >
                                        {% endif %}
                                        <span>{{ block.settings.option_one_line_2 }}</span>
                                      </div>
                                    {% endif %}

                                    {% if block.settings.option_one_line_3 != blank %}
                                      <div class="os-pdp-purchase-card__benefit-row">
                                        {% if block.settings.benefit_icon_2 != blank %}
                                          <img
                                            src="{{ block.settings.benefit_icon_2 | image_url: width: 40 }}"
                                            alt=""
                                            loading="lazy"
                                            width="18"
                                            height="18"
                                            class="os-pdp-purchase-card__benefit-icon"
                                          >
                                        {% endif %}
                                        <span>{{ block.settings.option_one_line_3 }}</span>
                                      </div>
                                    {% endif %}

                                    {% if block.settings.option_one_line_4 != blank %}
                                      <div class="os-pdp-purchase-card__benefit-row">
                                        {% if block.settings.benefit_icon_3 != blank %}
                                          <img
                                            src="{{ block.settings.benefit_icon_3 | image_url: width: 40 }}"
                                            alt=""
                                            loading="lazy"
                                            width="18"
                                            height="18"
                                            class="os-pdp-purchase-card__benefit-icon"
                                          >
                                        {% endif %}
                                        <span>{{ block.settings.option_one_line_4 }}</span>
                                      </div>
                                    {% endif %}
                                  </div>
                                {% endif %}
                              </span>
                            </button>
                          {% endfor %}
                        </div>
                      {% endif %}
                    </div>

                    {% if variant_picker_block %}
                      <div class="os-pdp-right__variants os-pdp-right__variants--hidden">
                        {% render 'product-variant-picker',
                          product: product,
                          block: variant_picker_block,
                          product_form_id: product_form_id
                        %}
                      </div>
                    {% endif %}

                    <div class="os-pdp-right__buy-row">
                      <input
                        type="hidden"
                        name="properties[Tipo de compra]"
                        value="Envío mensual"
                        data-purchase-hidden-input
                      >

                      {% if buy_buttons_block %}
                        <div class="os-pdp-right__buy-buttons">
                          {% render 'buy-buttons',
                            block: buy_buttons_block,
                            product: product,
                            product_form_id: product_form_id,
                            section_id: section.id,
                            show_pickup_availability: true
                          %}
                        </div>
                      {% endif %}
                    </div>

                    {% if block.settings.show_payments %}
                      <div class="os-pdp-right__payments">
                        {% if section.settings.os_payment_image != blank %}
                          <img
                            src="{{ section.settings.os_payment_image | image_url: width: 1200 }}"
                            alt="{{ section.settings.os_payment_image_alt | escape }}"
                            loading="lazy"
                            width="900"
                            height="80"
                          >
                        {% else %}
                          <ul class="os-pdp-payment-icons list-unstyled" role="list">
                            {%- for type in shop.enabled_payment_types -%}
                              <li class="os-pdp-payment-icons__item">
                                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                              </li>
                            {%- endfor -%}
                          </ul>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% if share_block and block.settings.show_share %}
                      <div class="os-pdp-right__share">
                        {% liquid
                          assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
                          render 'share-button', block: share_block, share_link: share_url
                        %}
                      </div>
                    {% endif %}
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
        </section>
      </div>
    </div>

    {% render 'product-media-modal', variant_images: variant_images %}

    {% assign popups = section.blocks | where: 'type', 'popup' %}
    {%- for block in popups -%}
      <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
        <div
          role="dialog"
          aria-label="{{ block.settings.text }}"
          aria-modal="true"
          class="product-popup-modal__content"
          tabindex="-1"
        >
          <button
            id="ModalClose-{{ block.id }}"
            type="button"
            class="product-popup-modal__toggle"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
          <div class="product-popup-modal__content-info">
            <h1 class="h2">{{ block.settings.page.title | escape }}</h1>
            {{ block.settings.page.content }}
          </div>
        </div>
      </modal-dialog>
    {%- endfor -%}

    {%- if product.media.size > 0 -%}
      <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if first_3d_model -%}
      <script type="application/json" id="ProductJSON-{{ product.id }}">
        {{ product.media | where: 'media_type', 'model' | json }}
      </script>
      <script src="{{ 'product-model.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- liquid
      if product.selected_or_first_available_variant.featured_media
