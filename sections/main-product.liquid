<script>
  document.addEventListener('DOMContentLoaded', function () {
    const wrappers = document.querySelectorAll('[data-purchase-options]');

    wrappers.forEach((wrapper) => {
      const cards = wrapper.querySelectorAll('[data-purchase-card]');
      const productRoot = wrapper.closest('.product');
      if (!productRoot || !cards.length) return;

      const variantWrapper = productRoot.querySelector('.os-pdp-right__variants--hidden');
      const hiddenPurchaseInput = productRoot.querySelector('[data-purchase-hidden-input]');

      const productSection = wrapper.closest('.shopify-section');
      const productForm = productSection ? productSection.querySelector('form[action*="/cart/add"]') : null;
      const variantIdInputs = productForm ? productForm.querySelectorAll('input[name="id"]') : [];
      const addToCartBtn = productForm ? productForm.querySelector('[name="add"]') : null;

      function getPriceNodes() {
        return {
          currents: productRoot.querySelectorAll('[data-custom-price-current]'),
          compares: productRoot.querySelectorAll('[data-custom-price-compare]'),
          badges: productRoot.querySelectorAll('[data-custom-price-badge]'),
          badgeValues: productRoot.querySelectorAll('[data-custom-price-badge-value]'),
        };
      }

      function moneyToNumber(value) {
        if (!value) return null;

        const cleaned = value
          .replace(/[^\d,.-]/g, '')
          .replace(/\./g, '')
          .replace(',', '.');

        const num = parseFloat(cleaned);
        return isNaN(num) ? null : num;
      }

      function updateAllPrices(card) {
        const { currents, compares, badges, badgeValues } = getPriceNodes();
        if (!currents.length) return;

        const current = card.getAttribute('data-price') || '';
        const compare = card.getAttribute('data-compare') || '';

        currents.forEach((node) => {
          node.textContent = current;
        });

        compares.forEach((node) => {
          if (compare) {
            node.textContent = compare;
            node.classList.remove('is-hidden');
          } else {
            node.textContent = '';
            node.classList.add('is-hidden');
          }
        });

        const currentNum = moneyToNumber(current);
        const compareNum = moneyToNumber(compare);
        let percent = 0;

        if (currentNum && compareNum && compareNum > currentNum) {
          percent = Math.round(((compareNum - currentNum) * 100) / compareNum);
        }

        badges.forEach((badge) => {
          if (percent > 0) {
            badge.classList.remove('is-hidden');
          } else {
            badge.classList.add('is-hidden');
          }
        });

        badgeValues.forEach((node) => {
          node.textContent = percent > 0 ? ' ' + percent + '%' : '';
        });
      }

      function syncNativeVariant(value) {
        if (!variantWrapper) return;

        const radioInputs = variantWrapper.querySelectorAll('input[type="radio"]');
        let matchedRadio = null;

        radioInputs.forEach((input) => {
          if (input.value === value) matchedRadio = input;
        });

        if (matchedRadio) {
          matchedRadio.checked = true;
          matchedRadio.dispatchEvent(new Event('change', { bubbles: true }));
          return;
        }

        const select = variantWrapper.querySelector('select');
        if (select) {
          select.value = value;
          select.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      function syncFormVariantId(variantId) {
        if (!variantIdInputs.length) return;

        variantIdInputs.forEach((input) => {
          input.value = variantId;
          input.dispatchEvent(new Event('change', { bubbles: true }));
        });

        if (addToCartBtn) {
          addToCartBtn.disabled = false;
          addToCartBtn.removeAttribute('disabled');
          addToCartBtn.classList.remove('disabled');
        }
      }

      function setHiddenPurchaseValue(card) {
        if (!hiddenPurchaseInput) return;

        const optionValue = card.getAttribute('data-option-value') || '';
        hiddenPurchaseInput.value = optionValue;
      }

      function setActiveCard(activeCard, syncNative = true) {
        cards.forEach((card) => {
          const isActive = card === activeCard;
          card.classList.toggle('is-active', isActive);
          card.classList.toggle('is-collapsed', !isActive);
          card.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });

        updateAllPrices(activeCard);
        setHiddenPurchaseValue(activeCard);

        const variantId = activeCard.getAttribute('data-variant-id');
        const optionValue = activeCard.getAttribute('data-option-value');

        if (variantId) {
          syncFormVariantId(variantId);
        }

        if (syncNative && optionValue) {
          syncNativeVariant(optionValue);
        }
      }

      cards.forEach((card) => {
        card.addEventListener('click', function () {
          setActiveCard(this, true);
        });
      });

      const initialActive = wrapper.querySelector('.is-active') || cards[0];
      if (initialActive) {
        setActiveCard(initialActive, false);
      }

      if (variantWrapper) {
        variantWrapper.addEventListener('change', function () {
          let selectedValue = null;

          const checkedRadio = variantWrapper.querySelector('input[type="radio"]:checked');
          if (checkedRadio) {
            selectedValue = checkedRadio.value;
          }

          const select = variantWrapper.querySelector('select');
          if (!selectedValue && select) {
            selectedValue = select.value;
          }

          if (!selectedValue) return;

          const matchingCard = wrapper.querySelector('[data-option-value="' + CSS.escape(selectedValue) + '"]');
          if (matchingCard) {
            setActiveCard(matchingCard, false);
          }
        });
      }
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const mobileBreakpoint = window.matchMedia('(max-width: 749px)');

    function moveProductBlocksMobile() {
      document.querySelectorAll('.product').forEach((product) => {
        const afterMediaSlot = product.querySelector('[data-mobile-after-media]');
        const rightCol = product.querySelector('.os-pdp-right');
        const offerPanel = product.querySelector('.os-pdp-right__panel--offer');

        if (!afterMediaSlot || !rightCol || !offerPanel) return;

        if (mobileBreakpoint.matches) {
          if (!product.dataset.mobileReordered) {
            const children = Array.from(rightCol.children);
            const offerIndex = children.indexOf(offerPanel);

            if (offerIndex !== -1) {
              const nodesToMove = children.slice(offerIndex);

              afterMediaSlot.classList.add('os-pdp-right', 'os-pdp-mobile-after-media--styled');

              const rightColInlineStyle = rightCol.getAttribute('style');
              if (rightColInlineStyle) {
                afterMediaSlot.setAttribute('style', rightColInlineStyle);
              }

              nodesToMove.forEach((node) => {
                afterMediaSlot.appendChild(node);
              });
            }

            const originalPrice = afterMediaSlot.querySelector('.os-pdp-right__price-wrap');

            if (originalPrice && !rightCol.querySelector('.os-pdp-mobile-price-duplicate')) {
              const clonedPrice = originalPrice.cloneNode(true);
              clonedPrice.classList.add('os-pdp-mobile-price-duplicate');
              rightCol.appendChild(clonedPrice);
            }

            product.dataset.mobileReordered = 'true';
          }
        } else {
          if (product.dataset.mobileReordered === 'true') {
            const movedNodes = Array.from(afterMediaSlot.children);

            movedNodes.forEach((node) => {
              rightCol.appendChild(node);
            });

            const duplicatedPrice = rightCol.querySelector('.os-pdp-mobile-price-duplicate');
            if (duplicatedPrice) duplicatedPrice.remove();

            afterMediaSlot.classList.remove('os-pdp-right', 'os-pdp-mobile-after-media--styled');
            afterMediaSlot.removeAttribute('style');

            delete product.dataset.mobileReordered;
          }
        }
      });
    }

    moveProductBlocksMobile();
    window.addEventListener('resize', moveProductBlocksMobile);
  });
</script>

