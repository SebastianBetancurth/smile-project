<script>
  document.addEventListener('DOMContentLoaded', function () {
    const rows = document.querySelectorAll('.os-pdp-description-tabs__row');

    rows.forEach((row) => {
      const summary = row.querySelector('summary');
      const content = row.querySelector('.os-pdp-description-tabs__content');
      const inner = row.querySelector('.os-pdp-description-tabs__content-inner');

      if (!summary || !content || !inner) return;

      if (row.hasAttribute('open')) {
        content.style.height = inner.offsetHeight + 'px';
        requestAnimationFrame(() => {
          content.style.height = 'auto';
          content.style.opacity = '1';
          content.style.transform = 'translateY(0)';
        });
      } else {
        content.style.height = '0px';
        content.style.opacity = '0';
        content.style.transform = 'translateY(-8px)';
      }

      summary.addEventListener('click', function (e) {
        e.preventDefault();

        const isOpen = row.hasAttribute('open');

        if (isOpen) {
          content.style.height = inner.offsetHeight + 'px';

          requestAnimationFrame(() => {
            row.classList.remove('is-opening');
            content.style.height = '0px';
            content.style.opacity = '0';
            content.style.transform = 'translateY(-8px)';
          });

          const onCloseEnd = function (event) {
            if (event.propertyName !== 'height') return;
            row.removeAttribute('open');
            content.removeEventListener('transitionend', onCloseEnd);
          };

          content.addEventListener('transitionend', onCloseEnd);
        } else {
          row.setAttribute('open', '');
          row.classList.add('is-opening');

          content.style.height = '0px';
          content.style.opacity = '0';
          content.style.transform = 'translateY(-8px)';

          requestAnimationFrame(() => {
            content.style.height = inner.offsetHeight + 'px';
            content.style.opacity = '1';
            content.style.transform = 'translateY(0)';
          });

          const onOpenEnd = function (event) {
            if (event.propertyName !== 'height') return;
            content.style.height = 'auto';
            row.classList.remove('is-opening');
            content.removeEventListener('transitionend', onOpenEnd);
          };

          content.addEventListener('transitionend', onOpenEnd);
        }
      });
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function initMobileMediaProgress() {
      if (window.innerWidth > 749) return;

      document.querySelectorAll('.product').forEach((product) => {
        const mediaWrapper = product.querySelector('.product__media-wrapper');
        const mediaList = product.querySelector('.product__media-list.slider');

        if (!mediaWrapper || !mediaList) return;

        const slides = Array.from(mediaList.querySelectorAll('.product__media-item'));
        if (slides.length < 2) return;

        const progress = document.createElement('div');
        progress.className = 'os-pdp-mobile-progress';

        const track = document.createElement('div');
        track.className = 'os-pdp-mobile-progress__track';

        const bar = document.createElement('span');
        bar.className = 'os-pdp-mobile-progress__bar';

        track.appendChild(bar);
        progress.appendChild(track);
        mediaWrapper.appendChild(progress);

        function updateProgress() {
          const maxScroll = mediaList.scrollWidth - mediaList.clientWidth;

          if (maxScroll <= 0) {
            bar.style.width = '100%';
            bar.style.transform = 'translateX(0)';
            return;
          }

          const ratioVisible = mediaList.clientWidth / mediaList.scrollWidth;
          const barWidth = Math.max(ratioVisible * 100, 18);
          const progressRatio = mediaList.scrollLeft / maxScroll;
          const maxTranslate = 100 - barWidth;
          const translate = progressRatio * maxTranslate;

          bar.style.width = barWidth + '%';
          bar.style.transform = 'translateX(' + translate + '%)';
        }

        updateProgress();
        mediaList.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', updateProgress);
      });
    }

    initMobileMediaProgress();
  });
</script>

