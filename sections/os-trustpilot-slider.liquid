{% liquid
  assign section_id = 'os-trustpilot-' | append: section.id
  assign review_count = section.blocks.size
%}

<section id="{{ section_id }}" class="os-trustpilot">
  <div class="os-trustpilot__inner">
    <div class="os-trustpilot__desktop-layout">
      <div class="os-trustpilot__summary os-trustpilot__summary--desktop">
        {% if section.settings.summary_title != blank %}
          <h2 class="os-trustpilot__summary-title">{{ section.settings.summary_title }}</h2>
        {% endif %}

        <div class="os-trustpilot__stars-row" aria-label="Trustpilot rating">
          <img
            src="{{ 'estrella_truspilot.png' | asset_url }}"
            alt=""
            loading="lazy"
            width="140"
            height="24"
            class="os-trustpilot__stars-strip os-trustpilot__stars-strip--summary"
          >
        </div>

        {% if section.settings.review_link_text != blank %}
          <div class="os-trustpilot__rating-text">
            {{ section.settings.review_prefix }}
            <a href="{{ section.settings.review_link_url | default: '#' }}">
              {{ section.settings.review_link_text }}
            </a>
          </div>
        {% endif %}

        <div class="os-trustpilot__brand">
          <img
            src="{{ 'trustpilot_logo.png' | asset_url }}"
            alt="Trustpilot"
            loading="lazy"
            width="160"
            height="38"
            class="os-trustpilot__brand-logo"
          >
        </div>
      </div>

      <div class="os-trustpilot__slider-wrap">
        <button
          type="button"
          class="os-trustpilot__nav os-trustpilot__nav--prev"
          aria-label="{{ section.settings.prev_label }}"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M14.7 5.3a1 1 0 0 1 0 1.4L10.41 11l4.29 4.3a1 1 0 1 1-1.41 1.4l-5-5a1 1 0 0 1 0-1.4l5-5a1 1 0 0 1 1.41 0z" fill="currentColor"/>
          </svg>
        </button>

        <div
          class="os-trustpilot__viewport"
          data-trustpilot-viewport
          tabindex="0"
          aria-roledescription="carousel"
          aria-label="{{ section.settings.carousel_label }}"
        >
          <div
            class="os-trustpilot__track"
            data-trustpilot-track
            data-original-count="{{ review_count }}"
          >
            {% for block in section.blocks %}
              <article
                class="os-trustpilot__slide"
                {{ block.shopify_attributes }}
                data-original-slide
              >
                <div class="os-trustpilot__card">
                  <div class="os-trustpilot__card-stars" aria-hidden="true">
                    {% assign block_stars = block.settings.stars | default: 5 %}
                    {% for i in (1..5) %}
                      <span class="os-trustpilot__review-star {% if i <= block_stars %}is-active{% else %}is-inactive{% endif %}">
                        <svg
                          class="tp-star"
                          viewBox="0 0 46 46"
                          width="20"
                          height="20"
                          xmlns="http://www.w3.org/2000/svg"
                          role="img"
                          aria-hidden="true"
                        >
                          <path class="tp-star__canvas" fill="var(--star-canvas)" d="M0 46.330002h46.375586V0H0z"></path>
                          <path class="tp-star__shape" d="M39.533936 19.711433L13.230239 38.80065l3.838216-11.797827L7.02115 19.711433h12.418975l3.837417-11.798624 3.837418 11.798624h12.418975zM23.2785 31.510075l7.183595-1.509576 2.862114 8.800152L23.2785 31.510075z" fill="var(--star-on)"></path>
                        </svg>
                      </span>
                    {% endfor %}
                  </div>
                  {% if block.settings.heading != blank %}
                    <h3 class="os-trustpilot__card-title">{{ block.settings.heading }}</h3>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="os-trustpilot__card-text rte">
                      {{ block.settings.text }}
                    </div>
                  {% endif %}

                  <div class="os-trustpilot__card-meta">
                    {% if block.settings.author != blank %}
                      <span class="os-trustpilot__card-author">{{ block.settings.author }}</span>
                    {% endif %}
                    {% if block.settings.date != blank %}
                      <span class="os-trustpilot__card-date">{{ block.settings.date }}</span>
                    {% endif %}
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
        </div>

        <button
          type="button"
          class="os-trustpilot__nav os-trustpilot__nav--next"
          aria-label="{{ section.settings.next_label }}"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M9.3 18.7a1 1 0 0 1 0-1.4L13.59 13 9.3 8.7a1 1 0 1 1 1.41-1.4l5 5a1 1 0 0 1 0 1.4l-5 5a1 1 0 0 1-1.41 0z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="os-trustpilot__summary os-trustpilot__summary--mobile">
      {% if section.settings.mobile_rating_text != blank %}
        <div class="os-trustpilot__mobile-rating">{{ section.settings.mobile_rating_text }}</div>
      {% endif %}

      <div class="os-trustpilot__brand os-trustpilot__brand--mobile">
        <img
          src="{{ 'trustpilot_logo.png' | asset_url }}"
          alt="Trustpilot"
          loading="lazy"
          width="160"
          height="38"
          class="os-trustpilot__brand-logo os-trustpilot__brand-logo--mobile"
        >
      </div>
    </div>
  </div>

  <style>
        @font-face {
            font-family: 'Circular Custom';
            src: url('{{ 'Delamere W01 Bold.woff' | asset_url }}') format('woff');
            font-weight:800;
            font-style: normal;
            font-display: swap;
    }
            #{{ section_id }} {
              --tp-bg: {{ section.settings.section_bg }};
              --tp-card-bg: {{ section.settings.card_bg }};
