  </style>

  <script>
    (function () {
      const section = document.getElementById('{{ section_id }}');
      if (!section) return;

      const viewport = section.querySelector('[data-trustpilot-viewport]');
      const track = section.querySelector('[data-trustpilot-track]');
      const prevBtn = section.querySelector('.os-trustpilot__nav--prev');
      const nextBtn = section.querySelector('.os-trustpilot__nav--next');

      if (!viewport || !track) return;

      let originalSlides = Array.from(track.querySelectorAll('[data-original-slide]'));
      let originalCount = originalSlides.length;

      if (originalCount <= 1) return;

      let currentIndex = 0;
      let cloneCount = 0;
      let slideStep = 0;
      let isAnimating = false;

      let pointerDown = false;
      let startX = 0;
      let currentTranslate = 0;
      let prevTranslate = 0;
      let dragMoved = false;

      const getGap = () => {
        const styles = window.getComputedStyle(track);
        return parseFloat(styles.columnGap || styles.gap || 0);
      };

      const getSlideWidth = () => {
        const firstSlide = track.querySelector('.os-trustpilot__slide');
        if (!firstSlide) return 0;
        return firstSlide.getBoundingClientRect().width;
      };

      const updateStep = () => {
        slideStep = getSlideWidth() + getGap();
      };

      const clearClones = () => {
        Array.from(track.querySelectorAll('[data-clone="true"]')).forEach((node) => node.remove());
      };

      const buildInfinite = () => {
        clearClones();

        originalSlides = Array.from(track.querySelectorAll('[data-original-slide]'));
        originalCount = originalSlides.length;

        if (originalCount <= 1) return;

        cloneCount = Math.min(originalCount, window.innerWidth <= 989 ? 2 : 4);

        const headClones = originalSlides.slice(0, cloneCount).map((slide) => {
          const clone = slide.cloneNode(true);
          clone.setAttribute('data-clone', 'true');
          return clone;
        });

        const tailClones = originalSlides.slice(-cloneCount).map((slide) => {
          const clone = slide.cloneNode(true);
          clone.setAttribute('data-clone', 'true');
          return clone;
        });

        tailClones.forEach((clone) => track.insertBefore(clone, track.firstChild));
        headClones.forEach((clone) => track.appendChild(clone));

        currentIndex = cloneCount;
        updateStep();
        jumpTo(currentIndex);
      };

      const setTranslate = (value, animate = true) => {
        track.style.transition = animate ? 'transform 0.42s ease' : 'none';
        track.style.transform = `translate3d(${value}px, 0, 0)`;
        currentTranslate = value;
      };

      const jumpTo = (index) => {
        const translate = -(index * slideStep);
        prevTranslate = translate;
        setTranslate(translate, false);
      };

      const goTo = (index) => {
        if (isAnimating || slideStep === 0) return;
        isAnimating = true;
        currentIndex = index;
        const translate = -(currentIndex * slideStep);
        prevTranslate = translate;
        setTranslate(translate, true);
      };

      const next = () => goTo(currentIndex + 1);
      const prev = () => goTo(currentIndex - 1);

      track.addEventListener('transitionend', () => {
        isAnimating = false;

        if (currentIndex >= originalCount + cloneCount) {
          currentIndex = cloneCount;
          jumpTo(currentIndex);
        } else if (currentIndex < cloneCount) {
          currentIndex = originalCount + cloneCount - 1;
          jumpTo(currentIndex);
        }
      });

      const pointerX = (event) => {
        if (event.touches && event.touches.length) return event.touches[0].clientX;
        if (event.changedTouches && event.changedTouches.length) return event.changedTouches[0].clientX;
        return event.clientX;
      };

      const onDragStart = (event) => {
        if (isAnimating) return;
        pointerDown = true;
        dragMoved = false;
        startX = pointerX(event);
        viewport.classList.add('is-dragging');
        track.style.transition = 'none';
      };

      const onDragMove = (event) => {
        if (!pointerDown) return;

        const currentX = pointerX(event);
        const diff = currentX - startX;

        if (Math.abs(diff) > 4) dragMoved = true;

        currentTranslate = prevTranslate + diff;
        track.style.transform = `translate3d(${currentTranslate}px, 0, 0)`;
      };

      const onDragEnd = () => {
        if (!pointerDown) return;
        pointerDown = false;
        viewport.classList.remove('is-dragging');

        const movedBy = currentTranslate - prevTranslate;
        const threshold = Math.max(slideStep * 0.16, 28);

        if (movedBy < -threshold) {
          next();
        } else if (movedBy > threshold) {
          prev();
        } else {
          setTranslate(prevTranslate, true);
        }
      };

      viewport.addEventListener('mousedown', onDragStart);
      viewport.addEventListener('touchstart', onDragStart, { passive: true });

      window.addEventListener('mousemove', onDragMove);
      window.addEventListener('touchmove', onDragMove, { passive: true });

      window.addEventListener('mouseup', onDragEnd);
      window.addEventListener('touchend', onDragEnd);

      viewport.addEventListener('mouseleave', () => {
        if (pointerDown) onDragEnd();
      });

      viewport.addEventListener(
        'click',
        (event) => {
          if (dragMoved) {
            event.preventDefault();
            event.stopPropagation();
          }
        },
        true
      );

      if (prevBtn) prevBtn.addEventListener('click', prev);
      if (nextBtn) nextBtn.addEventListener('click', next);

      viewport.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          prev();
        }
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          next();
        }
      });

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          buildInfinite();
        }, 120);
      });

      buildInfinite();
    })();
  </script>
</section>

