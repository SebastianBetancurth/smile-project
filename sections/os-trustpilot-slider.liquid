                font-size: {{ section.settings.card_text_size_mobile }}px;
              }

              #{{ section_id }} .os-trustpilot__brand-text {
                font-size: 26px;
              }
                #{{ section_id }} .os-trustpilot__card-author {
              font-weight: 700;
              color: #000000;
            }

                #{{ section_id }} {
                    overflow: hidden;
                }

                #{{ section_id }} .os-trustpilot__inner,
                #{{ section_id }} .os-trustpilot__inner.page-width {
                    max-width: 100%;
                    width: 100%;
                    padding-left: 0;
