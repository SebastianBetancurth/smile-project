              --tp-card-padding: {{ section.settings.card_padding }}px;
              --tp-desktop-summary-width: {{ section.settings.summary_width }}px;
              --tp-slide-width-desktop: {{ section.settings.slide_width_desktop }}px;
              --tp-slide-width-mobile: {{ section.settings.slide_width_mobile }}px;
              --tp-nav-size: {{ section.settings.arrow_size }}px;
              --tp-section-padding-top: {{ section.settings.padding_top }}px;
              --tp-section-padding-bottom: {{ section.settings.padding_bottom }}px;
