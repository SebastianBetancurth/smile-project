    "collapsible_content_mBUAq8": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_BPNpLh": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Qué hace diferente a esta pasta de dientes?",
            "icon": "check_mark",
            "row_content": "<p><strong>1. </strong>Cepillado normal con tu pasta de dientes habitual utilizando el cepillo de dientes.</p><p><strong>2. </strong>Aplica dos pulsaciones de la pasta de dientes en las cerdas del cepillo.</p><p><strong>3. </strong>Cepilla tus dientes con el Smile Project 3D Nanobrush durante 2-3 minutos, asegurándote de cubrir todas las áreas de tu boca.</p><p><strong>4. </strong>Continúa cepillando suavemente con el cepillo durante 30 segundos para asegurar una distribución uniforme de la pasta.</p><p><strong>5. </strong>Enjuaga la boca con agua abundante para eliminar cualquier residuo de pasta de dientes.</p>",
            "page": ""
          }
        },
        "collapsible_row_JQiJLz": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Se puede usar con carillas, empastes, fundas u ortodoncia?",
